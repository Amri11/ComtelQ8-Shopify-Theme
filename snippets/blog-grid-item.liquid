{%- liquid
  assign ratio = 1
  if article.image and settings.blog_image_ratio == 'portrait'
    assign ratio = 1.152
  elsif article.image and settings.blog_image_ratio == 'adapt'
    assign ratio = article.image.aspect_ratio
  endif
  if ratio == 0 or ratio == null
    assign ratio = 1
  endif
-%}
<div class="blog-block">
  <div class="blog-image">
    <a
      href="{{ article.url }}"
      class="blog-img ratio"
      style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;"
    >
      {%- if article.image != blank -%}
        {% assign image_height = article.image.src.width | divided_by: article.image.src.aspect_ratio %}
        {{
          article.image.src
          | image_url: width: 1080
          | image_tag: width: article.image.src.width, height: image_height, class: 'lazyload', loading: 'lazy'
        }}
      {%- else -%}
        {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
        {{ placeholder | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
      {%- endif -%}
    </a>
    <div class="post-tag">
      {% for tag in article.tags %}
      <a href="{{ tag | handleize | prepend:'/blogs/news/tagged/' }}">{{ tag }}</a>
      {% break %}
      {% endfor %}
    </div>
  </div>
  <div class="blog-post-content">
    <a href="{{ article.url }}" class="blog-title">{{ article.title | truncate: 40 }}</a>
    {%- if article.excerpt.size > 0 or article.content.size > 0 -%}
      <p class="mr-0 blog-desc">
        {%- if article.excerpt.size > 0 -%}
          {{ article.excerpt | strip_html | truncatewords: 50 }}
        {%- else -%}
          {{ article.content | strip_html | strip | truncate: 55 }}
        {%- endif -%}
      </p>
    {%- endif -%}
    {% if settings.blog_read_btn != '' %}
    <a href="{{ article.url }}" class="read-more">{{ settings.blog_read_btn }}</a>
    {% endif %}
  </div>
</div>
