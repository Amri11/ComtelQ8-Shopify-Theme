<!-- shop-top-bar start -->
<div class="shop-top-bar">
  <div class="shop-top-bar-left">
    <div class="product-filter">
      <button class="filter-button" type="button" aria-label="filter">
        <span>{{ 'collections.facets.filter_button' | t }}</span>
        <i class="feather-filter"></i>
      </button>
    </div>
    <span id="pro-count" class="product-count-text">
      {%- if results.results_count -%}
        {{
          'collections.facets.results_with_count'
          | t: terms: results.terms, count: results.results_count
        }}
      {%- elsif results.products_count == results.all_products_count -%}
        {{ 'collections.facets.product_count_simple' | t: count: results.products_count }}
      {%- else -%}
        {{
          'collections.facets.product_count'
          | t: product_count: results.products_count, count: results.all_products_count
        }}
      {%- endif -%}
    </span>
  </div>

  {% if section.settings.short_by_enable %}
    {%- liquid
      assign sort_by = results.sort_by | default: results.default_sort_by
      # On the search page a search term is present; preserve it (and the prefix
      # option) on the sort links and use the search-specific "relevance" option
      # instead of the collection-only "featured"/"best selling" options.
      assign is_search = false
      if results.terms
        assign is_search = true
        assign sort_base_url = '?q=' | append: results.terms | escape | append: '&options%5Bprefix%5D=last&sort_by='
      else
        assign sort_base_url = '?sort_by='
      endif
    -%}
    {%- liquid
      # NOTE: option values and labels are separated by "~~" (not ",") because
      # the translated labels themselves contain commas, e.g. "Price, low to high".
      if is_search
        capture sort_options
          echo 'relevance~~'
          echo 'collections.sorting.relevance' | t
        endcapture
      else
        capture sort_options
          echo 'manual~~'
          echo 'collections.sorting.featured' | t
          echo '|best-selling~~'
          echo 'collections.sorting.best_selling' | t
        endcapture
      endif
      capture sort_options_rest
        echo '|title-ascending~~'
        echo 'collections.sorting.az' | t
        echo '|title-descending~~'
        echo 'collections.sorting.za' | t
        echo '|price-ascending~~'
        echo 'collections.sorting.price_ascending' | t
        echo '|price-descending~~'
        echo 'collections.sorting.price_descending' | t
        echo '|created-descending~~'
        echo 'collections.sorting.date_descending' | t
        echo '|created-ascending~~'
        echo 'collections.sorting.date_ascending' | t
      endcapture
      assign sort_options = sort_options | append: sort_options_rest | split: '|'
      assign sort_current_label = ''
      for option in sort_options
        assign pair = option | split: '~~'
        if pair[0] == sort_by
          assign sort_current_label = pair[1]
        endif
      endfor
      if sort_current_label == ''
        assign first_pair = sort_options[0] | split: '~~'
        assign sort_current_label = first_pair[1]
      endif
    -%}
    <!-- product-short start -->
    <div class="product-short">
      <label for="SortBy">{{ 'collections.sorting.title' | t | append: ':' }}</label>
      <select class="nice-select" name="sortby" id="SortBy">
        {%- for option in sort_options -%}
          {%- assign pair = option | split: '~~' -%}
          <option value="{{ pair[0] }}">{{ pair[1] }}</option>
        {%- endfor -%}
      </select>
      <button class="short-title" aria-label="sort">
        <span class="sort-title">{{ sort_current_label }}</span>
        <span class="sort-icon"><i class="feather-chevron-down"></i></span>
      </button>
      <button class="short-title short-title-lg" aria-label="sort">
        <span class="sort-title">{{ sort_current_label }}</span>
        <span class="sort-icon"><i class="feather-chevron-down"></i></span>
      </button>
      <ul class="list-unstyled" role="list" id="select-wrap">
        {%- for option in sort_options -%}
          {%- assign pair = option | split: '~~' -%}
          <li{% if sort_by == pair[0] %} class="selected"{% endif %}>
            <a href="{{ sort_base_url }}{{ pair[0] }}">{{ pair[1] }}</a>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  {% endif %}
  <!-- product-short end -->
</div>
<!-- shop-top-bar end -->
<script type="text/javascript">
  addEventListener('DOMContentLoaded', (event) => {
    Shopify.queryParams = {};
    if (location.search.length) {
      for (var aKeyValue, i = 0, aCouples = location.search.substr(1).split('&'); i < aCouples.length; i++) {
        aKeyValue = aCouples[i].split('=');
        if (aKeyValue.length > 1) {
          Shopify.queryParams[decodeURIComponent(aKeyValue[0])] = decodeURIComponent(aKeyValue[1]);
        }
      }
    }
    var $select = $('#SortBy');
    $('a[href="#sort"]').click(function () {
      $select.val( $(this).data('select') );
      event.preventDefault();
      Shopify.queryParams.sort_by = jQuery(this).data('select');
      location.search = jQuery.param(Shopify.queryParams);
    });
    $('.list-change-view').on("click",function () {
      event.preventDefault();
      var data_grid = $(this).attr('data-grid-view');
      if($('.shop-product-wrap').hasClass('grid-1') || $('.shop-product-wrap').hasClass('grid-2') || $('.shop-product-wrap').hasClass('grid-3') || $('.shop-product-wrap').hasClass('grid-4')){
        $('.shop-product-wrap').removeClass('grid-1');
        $('.shop-product-wrap').removeClass('grid-2');
        $('.shop-product-wrap').removeClass('grid-3');
        $('.shop-product-wrap').removeClass('grid-4');
        $('.shop-product-wrap').addClass('grid-'+data_grid);
      }else{
        $('.shop-product-wrap').addClass('grid-'+data_grid);
      }
    });
    $('.list-change-view').on("click",function () {
      $('.list-change-view').removeClass('active');
      $(this).addClass('active');
    });

    $(function() {
      $('#SortBy').val('{{ results.sort_by | default: results.default_sort_by }}').bind('change', function() {
        Shopify.queryParams.sort_by = jQuery(this).val();
        location.search = jQuery.param(Shopify.queryParams);
      });
    });

    $('.product-short .short-title-lg').on('click', function () {
      if ($('#select-wrap').hasClass('active')) {
        $('#select-wrap').removeClass('active');
        $(this).removeClass('active');
      }
      else {
        $('#select-wrap').addClass('active');
        $(this).addClass('active');
      }
    });

    // desktop: "Filters" button collapses/shows the sidebar column
    $('.shop-top-bar .filter-button').on('click', function () {
      if (window.matchMedia('(min-width: 1200px)').matches) {
        $('.pro-grli-wrapper').toggleClass('filters-hidden');
      }
    });
  });
</script>
<style>
  /*=====================================
    collection sorting css
  ======================================*/
  /* shop top bar css */
  .shop-top-bar {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    margin-top: 0;
    margin-bottom: 30px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--theme-border-color);
  }

  /* left group: filters + count */
  .shop-top-bar .shop-top-bar-left {
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .shop-top-bar .shop-top-bar-left .product-count-text {
    color: var(--font-color-body);
    font-size: 14px;
    opacity: 0.65;
    line-height: 1;
  }

  /* filter button css */
  .shop-top-bar .product-filter button.filter-button {
    color: var(--font-color-header);
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 16px;
    font-weight: 600;
    line-height: 1;
    cursor: pointer;
  }
  .shop-top-bar .product-filter button.filter-button span {
    color: var(--font-color-header);
    font-size: 14px;
    font-weight: 500;
    line-height: 1;
  }
  .shop-top-bar .product-filter button.filter-button i {
    font-size: 15px;
    line-height: 0;
    color: var(--font-color-header);
  }

  /* product sorting css */
  .product-short {
    display: flex;
    align-items: center;
    position: relative;
  }
  .product-short label {
    color: var(--font-color-header);
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 0;
    line-height: 1;
  }
  .product-short select {
    display: none;
    color: var(--font-color-body);
    font-size: var(--font-size-body);
    min-width: 200px;
    background-color: transparent;
    border: none;
  }
  @media (max-width: 767px) {
    .product-short select {
      display: block;
    }
  }
  @media (max-width: 479px) {
    .product-short {
      order: 1;
      width: 100%;
    }
    .product-short label {
      width: 90px;
    }
    .product-short select {
      min-width: auto;
      width: 100%;
    }
  }

  /* product sorting ul li css */
  .product-short .short-title {
    color: var(--font-color-header);
    font-size: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0;
    padding-inline-start: 8px;
  }
  .product-short .short-title:hover {
    color: var(--font-color-primary);
  }
  .product-short .short-title span.sort-title {
    display: block;
  }
  .product-short .short-title span.sort-icon {
    display: block;
    line-height: 0;
  }
  .product-short .short-title span.sort-icon i {
    display: block;
    line-height: 0;
  }
  .product-short .short-title span.sort-icon i::before {
    font-weight: 600!important;
  }
  .product-short .short-title.short-title-lg {
    display: none;
  }
  .product-short ul {
    position: absolute;
    inset-inline-end: 0;
    min-width: 180px;
    top: calc(100% - -10px);
    z-index: 2;
    opacity: 0;
    visibility: hidden;
    background-color: var(--background-color-body);
    border-radius: 6px;
    box-shadow: 0px 0px 15px rgba(0, 0, 0, 0.15);
    overflow: hidden;
  }
  .product-short:hover ul {
    opacity: 1;
    visibility: visible;
  }
  .product-short ul,
  .product-short:hover ul {
    -webkit-transition: all 0.3s ease-in-out 0s;
    -o-transition: all 0.3s ease-in-out 0s;
    transition: all 0.3s ease-in-out 0s;
  }
  .product-short ul li a {
    display: block;
    color: var(--font-color-body);
    padding: 10px 20px;
    background-color: var(--background-color-body);
  }
  .product-short ul li:hover a,
  .product-short ul li.selected a {
    color: var(--font-color-header);
  }
  @media (max-width: 1199px) {
    .product-short .short-title {
      display: none;
    }
    .product-short .short-title.short-title-lg {
      color: var(--font-color-body);
      display: flex;
    }
    .product-short .short-title.short-title-lg.active {
      color: var(--font-color-header);
    }
    .product-short ul.active {
      opacity: 1;
      visibility: visible;
    }
    .product-short ul,
    .product-short:hover ul {
      -webkit-transition: all 0s ease-in-out 0s;
      -o-transition: all 0s ease-in-out 0s;
      transition: all 0s ease-in-out 0s;
    }
  }
  @media (max-width: 767px) {
    .product-short .short-title.short-title-lg {
      display: none;
    }
    .product-short ul {
      display: none;
    }
  }
  @media (max-width: 479px) {
    .product-short .short-title {
      min-width: auto;
      width: 100%;
    }
  }
</style>
