{% liquid
  if template contains 'article' or template contains 'blog'
    capture permalink_url
      echo shop.url
      echo article.url
    endcapture
    capture share_title
      echo article.title | url_param_escape
    endcapture
  elsif template contains 'product'
    capture permalink_url
      echo shop.url
      echo product.url
    endcapture
    capture share_title
      echo product.title | url_param_escape
    endcapture
  elsif template == 'password'
    capture permalink_url
      echo shop.url
    endcapture
    capture share_title
      unless shop.description == blank
        echo shop.description | url_param_escape
      else
        echo shop.name | url_param_escape
      endunless
    endcapture
  endif
-%}
<ul class="list-unstyled pro_social_link">
  <li>
    <a
      target="_blank"
      href="//www.facebook.com/sharer.php?u={{ permalink_url }}"
      class="facebook"
      title="Share on Facebook"
      tabindex="0"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        width="24"
        height="24"
        fill="none"
        class="main-grid-item-icon"
      >
        <path d="m17.543 13.398.661-4.31h-4.136V6.29c0-1.18.578-2.329 2.43-2.329h1.88V.291S16.673 0 15.042 0c-3.407 0-5.633 2.064-5.633 5.802v3.285H5.622v4.311h3.786v10.42a15.015 15.015 0 0 0 4.66 0v-10.42h3.475Z" fill="#1877F2"></path>
      </svg>
    </a>
  </li>
  <li>
    <a
      target="_blank"
      href="//twitter.com/share?text={{ share_title }}&amp;url={{ permalink_url }};source=webclient"
      class="twitter"
      title="Share on Twitter"
      tabindex="0"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M10.4883 14.651L15.25 21H22.25L14.3917 10.5223L20.9308 3H18.2808L13.1643 8.88578L8.75 3H1.75L9.26086 13.0145L2.31915 21H4.96917L10.4883 14.651ZM16.25 19L5.75 5H7.75L18.25 19H16.25Z" fill="#222222"/></svg>
    </a>
  </li>
  <li>
    <a
      target="_blank"
      href="//telegram.me/share/url?url={{ permalink_url }}"
      class="telegram"
      title="Share on Twitter"
      tabindex="0"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        width="24"
        height="24"
        fill="none"
        class="main-grid-item-icon"
      >
        <path clip-rule="evenodd" d="M1.65 11.562c6.442-2.807 10.738-4.657 12.888-5.551C20.675 3.458 21.95 3.015 22.782 3c.182-.004.591.041.856.256.223.182.285.427.314.599.03.172.066.563.037.87-.332 3.494-1.771 11.974-2.503 15.888-.31 1.656-.92 2.211-1.51 2.266-1.284.118-2.259-.848-3.502-1.663-1.945-1.275-3.043-2.069-4.931-3.313-2.182-1.438-.768-2.228.476-3.52.325-.338 5.98-5.481 6.089-5.948.014-.058.026-.275-.103-.39-.13-.115-.32-.076-.457-.045-.196.045-3.303 2.099-9.322 6.162-.882.605-1.681.9-2.397.885-.789-.017-2.307-.446-3.435-.813-1.384-.45-2.484-.688-2.388-1.452.05-.398.598-.805 1.644-1.22Z" fill="url(#telegram__a)" fill-rule="evenodd"></path><defs><linearGradient gradientUnits="userSpaceOnUse" id="telegram__a" x1="12" x2="12" y1="3" y2="22.742"><stop stop-color="#2AABEE"></stop><stop offset="1" stop-color="#229ED9"></stop></linearGradient></defs>
      </svg>
    </a>
  </li>
  {% if product.featured_image or article.image %}
    <li>
      <a
        target="_blank"
        href="//pinterest.com/pin/create/button/?url={{ permalink_url }}&amp;media=http:{% if template contains 'product' %}{{ product | image_url: width: 1024 }}{% else %}{{ article | image_url: width: 1024 }}{% endif %}&amp;description={{ share_title }}"
        class="pinterest"
        title="Share on Pinterest"
        tabindex="0"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          width="24"
          height="24"
          fill="none"
          class="main-grid-item-icon"
        >
          <path d="M12.049 0C5.489 0 2 4.215 2 8.811c0 2.132 1.188 4.79 3.09 5.633.288.13.445.075.51-.194.056-.203.306-1.186.427-1.65a.426.426 0 0 0-.101-.417c-.632-.732-1.133-2.065-1.133-3.316 0-3.206 2.542-6.318 6.867-6.318 3.74 0 6.357 2.436 6.357 5.92 0 3.938-2.079 6.662-4.779 6.662-1.494 0-2.607-1.176-2.254-2.63.426-1.733 1.262-3.597 1.262-4.846 0-1.12-.631-2.048-1.92-2.048-1.522 0-2.756 1.51-2.756 3.539 0 1.289.455 2.159.455 2.159L6.24 18.539c-.473 1.928.064 5.05.11 5.318.029.149.195.195.288.074.148-.195 1.967-2.798 2.477-4.679.186-.686.947-3.465.947-3.465.501.907 1.948 1.668 3.489 1.668 4.584 0 7.896-4.04 7.896-9.053C21.43 3.596 17.328 0 12.049 0Z" fill="#E53333"></path>
        </svg>
      </a>
    </li>
  {% endif %}
</ul>
<style>
  ul.pro_social_link{
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
  }
  ul.pro_social_link li a svg{
    width: 18px;
  }
</style>
