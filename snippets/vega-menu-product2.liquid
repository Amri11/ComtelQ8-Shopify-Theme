<li class="menu-link">
  <a href="{{ block.settings.menu_product_url }}" class="link-title">
    {% if block.settings.menuvega_link_image %}
    <span class="menu-img-icon">
    {{ block.settings.menuvega_link_image
      | image_url: width: 100
      | image_tag:
        loading: 'lazy',
        width: block.settings.menuvega_link_image.width,
        height: block.settings.menuvega_link_image.height,
        class: 'img-fluid lazyload',
        alt: block.settings.menuvega_link_image.alt
      | escape }}
    </span>
    {% endif %}
    <span class="sp-link-title">{{ block.settings.menu_product_title }}{% if block.settings.menu_product_label != '' %}<span class="{{ section.id }}-{{ block.id }}-label">{{ block.settings.menu_product_label }}</span>{% endif %}</span>
    <span class="menu-arrow"><i class="fa fa-angle-down"></i></span>
  </a>
  <div class="link-title-lg">
    <a href="{{ block.settings.menu_product_url }}" class="sp-link-title">{{ block.settings.menu_product_title }}</a>
    <a href="#single-collapse-{{ block.settings.menu_product_title | handleize }}" data-bs-toggle="collapse" class="menu-arrow"><i class="feather-plus"></i></a>
  </div>
  <ul class="list-unstyled menu-dropdown product-menu2 collapse" id="single-collapse-{{ block.settings.menu_product_title | handleize }}">
    <div class="ul">
      {% if block.settings.menu_product_collection_select != '' %}
      {%- assign menu_product_collection_select = block.settings.menu_product_collection_select -%}
      <li class="productlink-li menu-li">
        {% for link in linklists[menu_product_collection_select].links %}
        <div class="shop-title">
          <a href="{{ link.url }}">{{ link.title | upcase }}</a>
        </div>
        {% endfor %}
      </li>
      {% else %}
      {% assign menu_product_select = block.settings.menu_product_select %}
      {% for link in linklists[menu_product_select].links %}
      {% assign sublink = link.title | handle %}
      {% if linklists[sublink].links != '' %}
      <li class="productlink-li">
        <a href="{{ link.url }}" class="productlink-title">
          <span class="sp-link-title">{{ link.title }}</span>
        </a>
        <div class="productlink-title productlink-title-lg">
          <a href="{{ link.url }}" class="sp-link-title">{{ link.title }}</a>
          <a href="#productsup-collapse-{{ link.title | handleize }}" data-bs-toggle="collapse" class="menu-arrow"><i class="feather-plus"></i></a>
        </div>
        <ul class="list-unstyled productsupmenu-dropdown collapse" id="productsup-collapse-{{ link.title | handleize }}">
          {% for sublink in linklists[sublink].links %}
          <li class="productsupmenu-li">
            <a href="{{ sublink.url }}" class="productsuplink-title">
              <span class="sp-link-title">{{ sublink.title }}</span>
            </a>
          </li>
          {% endfor %}
        </ul>
      </li>
      {% endif %}
      {% endfor %}      
      {% endif %}
      
      {% if block.settings.menu_product_collection_select2 != '' %}
      {%- assign menu_product_collection_select2 = block.settings.menu_product_collection_select2 -%}
      <li class="productlink-li menu-li">
        {% for link in linklists[menu_product_collection_select2].links %}
        <div class="shop-title">
          <a href="{{ link.url }}">{{ link.title | upcase }}</a>
        </div>
        {% endfor %}
      </li>
      {% else %}
      {% assign menu_product_select2 = block.settings.menu_product_select2 %}
      {% for link in linklists[menu_product_select2].links %}
      {% assign sublink = link.title | handle %}
      {% if linklists[sublink].links != '' %}
      <li class="productlink-li">
        <a href="{{ link.url }}" class="productlink-title">
          <span class="sp-link-title">{{ link.title }}</span>
        </a>
        <div class="productlink-title productlink-title-lg">
          <a href="{{ link.url }}" class="sp-link-title">{{ link.title }}</a>
          <a href="#productsup-collapse-{{ link.title | handleize }}" data-bs-toggle="collapse" class="menu-arrow"><i class="feather-plus"></i></a>
        </div>
        <ul class="list-unstyled productsupmenu-dropdown collapse" id="productsup-collapse-{{ link.title | handleize }}">
          {% for sublink in linklists[sublink].links %}
          <li class="productsupmenu-li">
            <a href="{{ sublink.url }}" class="productsuplink-title">
              <span class="sp-link-title">{{ sublink.title }}</span>
            </a>
          </li>
          {% endfor %}
        </ul>
      </li>
      {% endif %}
      {% endfor %}
      {% endif %}
      {% assign menu_product_collection1 = collections[block.settings.menu_product_collection1] %}
      <li class="productlink-li menu-product">
        <div class="product-title">
          <h6 class="mr-0">{{ block.settings.product_title }}</h6>
          <div class="swiper-buttons">
            <button class="swiper-prev swiper-prev-{{ block.id }}"><i class=" feather-arrow-left"></i></button>
            <button class="swiper-next swiper-next-{{ block.id }}"><i class=" feather-arrow-right"></i></button>
          </div>  
        </div>
        <div class="swiper" id="pro-{{ block.id }}" data-slides-per-view="2">
          <div class="swiper-wrapper">
            {% for product in menu_product_collection1.products limit: block.settings.menu_product_collection1_limit %}
            <div class="swiper-slide">
              <div class="{{ section.id }}-{{ block.id }}-product-menu-grid">
                {% render 'product-menu-grid', product: product %}
              </div>
            </div>
            {% endfor %}
          </div>
        </div>
      </li>
    </div>
  </ul>
</li>

<script type="text/javascript">
  addEventListener('DOMContentLoaded', (event) => {
    var swiper = new Swiper('#pro-{{ block.id }}', {
      slidesPerView: 2,
      grid: {
        rows: 1,
        fill: 'row' | 'column',
      },
      spaceBetween: 30,
      observer: true,
      observeParents: true,
      watchSlidesProgress: true,
      {% if request.locale.iso_code == 'ar' %}
      rtl: true,
      {%- endif -%}
      navigation: {
        nextEl: '.swiper-next-{{ block.id }}',
        prevEl: '.swiper-prev-{{ block.id }}',
      },
      pagination: {
        el: ".swiper-pagination-{{ block.id }}",
        clickable: true
      },
      // autoplay: {
      //   delay: 5000,
      //   disableOnInteraction: false,
      //   pauseOnMouseEnter: true
      // },
      // speed: 1000,
      breakpoints: {
        1199: {
          slidesPerView: 2,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 30,
        },
        1499: {
          slidesPerView: 2,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 30,
        }
      }
    });
  });
</script>

<style>
/*=====================================
  header label css
======================================*/
a.link-title span.sp-link-title span.{{ section.id }}-{{ block.id }}-label {
  color: {{ block.settings.menu_product_label_color }};
  font-size: {{ block.settings.menu_product_label_font_size }}px;
  padding: 2px 5px;
  position: absolute;
  top: -{{ block.settings.menu_product_label_top_position }}px;
  {% if request.locale.iso_code == 'ar' %}
  left: 0;
  transform: translateX(-100%);
  {% else %}
  right: 0;
  transform: translateX(100%);
  {% endif %}
  background-color: {{ block.settings.menu_product_label_bgcolor }};
  text-transform: {{ block.settings.menu_product_label_text_transform }};
  font-weight: {{ block.settings.menu_product_label_font-weight }};
  border-radius: {{ block.settings.menu_product_label_border_radius }}px;
  line-height: {{ block.settings.menu_product_label_line_height }};
}
a.link-title span.sp-link-title span.{{ section.id }}-{{ block.id }}-label::before {
  content: "";
  position: absolute;
  bottom: -4px;
  {% if request.locale.iso_code == 'ar' %}
  right: 0;
  {% else %}
  left: 0;
  {% endif %}
  border-top: 4px solid transparent;
  border-bottom: 4px solid transparent;
  {% if request.locale.iso_code == 'ar' %}
  border-right: 4px solid {{ block.settings.menu_product_label_bgcolor }};
  {% else %}
  border-left: 4px solid {{ block.settings.menu_product_label_bgcolor }};
  {% endif %}
}
@media (max-width: 1199px) {
  a.link-title span.sp-link-title span.{{ section.id }}-{{ block.id }}-label {
    top: -8px;
  }
}

/*=====================================
  product menu-list css
======================================*/
.{{ section.id }}-{{ block.id }}-product-menu-grid .product-menu-grid .product-image {
  border-radius: var(--sti-border-radius);
  overflow: hidden;
  position: relative;
  display: block;
}
.{{ section.id }}-{{ block.id }}-product-menu-grid .product-menu-grid .product-image .product-grid-rating {
  background-color: var(--font-color-primary);
  color: #fff;
  font-size: 14px;
  padding: 8px 17px;
  position: absolute;
  top: 15px;
  right: 15px;
  display: flex;
  align-items: center;
  border-radius: var(--sti-border-radius);
  line-height: 1;
}
.{{ section.id }}-{{ block.id }}-product-menu-grid .product-menu-grid .product-image .product-grid-rating .rating-star {
  color: var(--font-color-secondary);
  padding-inline-end: 5px;
}
.{{ section.id }}-{{ block.id }}-product-menu-grid .product-menu-grid .product-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  margin-top: 15px;
}
.{{ section.id }}-{{ block.id }}-product-menu-grid .product-menu-grid .product-content h6 {
  font-size: var(--font-size-body);
  font-weight: var(--font-custom-weight-body);
}
.{{ section.id }}-{{ block.id }}-product-menu-grid .product-menu-grid .product-content h6 a {
  color: var(--font-color-header);
}
.{{ section.id }}-{{ block.id }}-product-menu-grid .product-menu-grid .product-content h6 a:hover {
  color: var(--font-color-primary);
}
.{{ section.id }}-{{ block.id }}-product-menu-grid .product-menu-grid .product-content .product-grid-rating {
  color: #fff;
  font-size: 14px;
  display: flex;
  align-items: center;
  line-height: 1;
  padding: 7px 16px;
  margin-top: 14px;
  background-color: var(--font-color-primary);
  border-radius: var(--sti-border-radius);
}
.{{ section.id }}-{{ block.id }}-product-menu-grid .product-menu-grid .product-content .price-box {
  margin-top: 10px;
}
.{{ section.id }}-{{ block.id }}-product-menu-grid .product-menu-grid .product-content .price-box .new-price,
.{{ section.id }}-{{ block.id }}-product-menu-grid .product-menu-grid .product-content .price-box .old-price {
  color: var(--font-color-header);
  font-size: var(--font-size-body);
  font-weight: var(--font-subtitle-weight-body);
}
html[dir=rtl] .megamenu-content .mainwrap ul.main-menu li.menu-link ul.menu-dropdown.product-menu2 .menu-product .product-title .swiper-buttons {
  direction: ltr;
}
</style>