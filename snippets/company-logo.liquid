{%- if settings.logo_header != blank -%}
  <a href="{{ routes.root_url }}" class="theme-header-logo" style="max-width: {{ settings.logo_header_max_width }}px;">
    {% if settings.logo_header.src != blank %}
      {{
        settings.logo_header.src
        | image_url: width: 500
        | image_tag:
          loading: 'lazy',
          width: settings.logo_header.width,
          height: settings.logo_header.height,
          class: 'lazyload main-logo',
          loading: 'lazy',
          alt: shop.name
        | escape
      }}
    {% endif %}
  </a>
{%- else -%}
  <a href="{{ routes.root_url }}" class="theme-header-logo">
    <span>{{ shop.name }}</span>
  </a>
{%- endif -%}
<style>
  /* logo css */
  a.theme-header-logo {
    display: block;
    word-break: break-word;
  }
  a.theme-header-logo img {
    max-width: {{ settings.logo_header_max_width }}px;
  }
  @media (max-width: 479px) {
    a.theme-header-logo img {
      max-width: 105px;
    }
  }
  /* store css */
  a.theme-header-logo {
    display: block;
  }
  a.theme-header-logo span {
    color: var(--font-color-header);
    font-size: 16px;
    font-weight: 600;
  }
</style>
