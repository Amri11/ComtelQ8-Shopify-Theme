{{ 'store-location.css' | asset_url | stylesheet_tag }}
<section
  class="store-location"
  style="--padding-top: {{ section.settings.section_padding_top }}px;--padding-bottom: {{ section.settings.section_padding_bottom }}px; --padding-top-xs: {{ section.settings.section_padding_top_xs }}px;--padding-bottom-xs: {{ section.settings.section_padding_bottom_xs }}px; --background-color: {{ section.settings.section_background_color }};"
>
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    {% if section.settings.section_subheading != blank or section.settings.section_heading != blank %}
      <div class="section-capture">
        <div class="section-title">
          {% if section.settings.section_subheading != blank %}
            <span data-fade-in class="sub-title">{{ section.settings.section_subheading }}</span>
          {% endif %}
          {% if section.settings.section_heading != blank %}
            <h2 class="mr-0" data-fade-in>{{ section.settings.section_heading }}</h2>
          {% endif %}
        </div>
      </div>
    {% endif %}

    <div class="store-grid">
      {% for block in section.blocks %}
        <div class="store-card" {{ block.shopify_attributes }}>
          <div class="store-card-map">
            {%- if block.settings.map_embed != blank -%}
              {{ block.settings.map_embed }}
            {%- else -%}
              <div class="store-card-map-placeholder">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
              </div>
            {%- endif -%}
          </div>

          <div class="store-card-info">
            {% if block.settings.store_title != blank %}
              <h3 class="store-card-title mr-0" data-fade-in>{{ block.settings.store_title }}</h3>
            {% endif %}

            <ul class="store-card-list list-unstyled">
              {% if block.settings.store_address != blank %}
                <li class="store-card-row" data-fade-in>
                  <span class="store-card-icon"><i class="feather-map-pin"></i></span>
                  <div class="store-card-text">
                    <span class="store-card-label">{{ 'sections.store_location.address' | t | default: 'Address' }}</span>
                    <p class="mr-0">{{ block.settings.store_address }}</p>
                  </div>
                </li>
              {% endif %}

              {% if block.settings.store_phone != blank %}
                <li class="store-card-row" data-fade-in>
                  <span class="store-card-icon"><i class="feather-phone-call"></i></span>
                  <div class="store-card-text">
                    <span class="store-card-label">{{ 'sections.store_location.phone' | t | default: 'Phone' }}</span>
                    <a href="tel:{{ block.settings.store_phone | strip | replace: ' ', '' }}">{{ block.settings.store_phone }}</a>
                  </div>
                </li>
              {% endif %}

              {% if block.settings.store_email != blank %}
                <li class="store-card-row" data-fade-in>
                  <span class="store-card-icon"><i class="feather-mail"></i></span>
                  <div class="store-card-text">
                    <span class="store-card-label">{{ 'sections.store_location.email' | t | default: 'Email' }}</span>
                    <a href="mailto:{{ block.settings.store_email }}">{{ block.settings.store_email }}</a>
                  </div>
                </li>
              {% endif %}

              {% if block.settings.store_hours != blank %}
                <li class="store-card-row" data-fade-in>
                  <span class="store-card-icon"><i class="feather-clock"></i></span>
                  <div class="store-card-text">
                    <span class="store-card-label">{{ 'sections.store_location.hours' | t | default: 'Opening hours' }}</span>
                    <p class="mr-0">{{ block.settings.store_hours }}</p>
                  </div>
                </li>
              {% endif %}
            </ul>

            {% if block.settings.directions_url != blank %}
              <a
                href="{{ block.settings.directions_url }}"
                class="store-card-directions"
                target="_blank"
                rel="noopener"
              >
                {{ block.settings.directions_label | default: 'Get directions' }}
                <i class="feather-arrow-right"></i>
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Store location",
  "settings": [
    {
      "type": "header",
      "content": "Section width"
    },
    {
      "type": "select",
      "id": "container",
      "label": "Section width",
      "options": [
        {
          "label": "Fluid",
          "value": "fluid"
        },
        {
          "label": "Normal",
          "value": "normal"
        }
      ],
      "default": "normal"
    },
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "text",
      "id": "section_subheading",
      "label": "Subheading",
      "default": "Visit us"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Heading",
      "default": "Our stores"
    },
    {
      "type": "header",
      "content": "Section space top bottom"
    },
    {
      "type": "paragraph",
      "content": "Desktop"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Space top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Space bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 100
    },
    {
      "type": "paragraph",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "section_padding_top_xs",
      "label": "Space top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom_xs",
      "label": "Space bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Section background color"
    },
    {
      "type": "color",
      "id": "section_background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "store",
      "name": "Store",
      "settings": [
        {
          "type": "text",
          "id": "store_title",
          "label": "Store name",
          "default": "Store name"
        },
        {
          "type": "text",
          "id": "store_phone",
          "label": "Phone number",
          "default": "+965 0000 0000"
        },
        {
          "type": "text",
          "id": "store_email",
          "label": "Email address",
          "info": "Optional"
        },
        {
          "type": "textarea",
          "id": "store_address",
          "label": "Address",
          "default": "Store address, City, Country"
        },
        {
          "type": "textarea",
          "id": "store_hours",
          "label": "Opening hours",
          "info": "Optional",
          "default": "Sun - Thu : 9:00am - 9:00pm"
        },
        {
          "type": "header",
          "content": "Google map"
        },
        {
          "type": "textarea",
          "id": "map_embed",
          "label": "Google map embed",
          "info": "On Google Maps: Share > Embed a map > copy the full <iframe> code and paste it here."
        },
        {
          "type": "url",
          "id": "directions_url",
          "label": "Directions link",
          "info": "Optional. Link to the store on Google Maps."
        },
        {
          "type": "text",
          "id": "directions_label",
          "label": "Directions button text",
          "default": "Get directions"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store location",
      "blocks": [
        {
          "type": "store"
        },
        {
          "type": "store"
        },
        {
          "type": "store"
        }
      ]
    }
  ]
}
{% endschema %}
