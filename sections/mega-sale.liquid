    },
    {
      "type": "select",
      "id": "slider_item_ipadpro",
      "label": "Ipadpro item",
      "info": "Width : > 1024px",
      "options": [
        { "label": "2", "value": "2" },
        { "label": "2.5", "value": "2.5" },
        { "label": "3", "value": "3" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "slider_item_ipad",
      "label": "Ipad item",
      "info": "Width : > 540px",
      "options": [
        { "label": "2", "value": "2" },
        { "label": "2.5", "value": "2.5" },
        { "label": "3", "value": "3" }
      ],
      "default": "2.5"
    },
    {
      "type": "select",
      "id": "slider_item_mobile",
      "label": "Mobile item",
      "info": "Width : < 540px",
      "options": [
        { "label": "1.2", "value": "1.2" },
        { "label": "1.5", "value": "1.5" },
        { "label": "2", "value": "2" }
      ],
      "default": "1.5"
    },
    {
      "type": "header",
      "content": "Slider autoplay"
    },
    {
      "type": "checkbox",
      "id": "slider_loop",
      "label": "Loop slides",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "slider_autoplay_enable",
      "label": "Show autoplay",
      "default": false
    },
    {
      "type": "number",
      "id": "slider_autoplay_timeout",
      "label": "Autoplay timeout",
      "default": 5000,
      "info": "Put timeout by multiply 'X1000' this field"
    },
    {
      "type": "number",
      "id": "slider_autoplay_speed",
      "label": "Autoplay speed",
      "default": 1000,
      "info": "Put speed by multiply 'X100' this field"
    },
    {
      "type": "checkbox",
      "id": "arrow_enable",
      "label": "Show slider arrow",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "dots_enable",
      "label": "Show slider dots",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Mega Sale"
    }
  ]
}
{% endschema %}
