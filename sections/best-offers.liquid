{{ 'best-offers.css' | asset_url | stylesheet_tag }}
<section
  class="best-offers best-offers-{{ section.id }}"
  style="--padding-top: {{ section.settings.section_padding_top }}px;--padding-bottom: {{ section.settings.section_padding_bottom }}px;--padding-top-xs: {{ section.settings.section_padding_top_xs }}px;--padding-bottom-xs: {{ section.settings.section_padding_bottom_xs }}px;--background-color: {{ section.settings.section_bg_color }};--card-radius: {{ section.settings.card_radius }}px;--grid-gap: {{ section.settings.grid_gap }}px;"
>
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    {% if section.settings.section_heading != '' %}
      <div class="best-offers-head">
        <h2 class="mr-0" data-fade-in>{{ section.settings.section_heading }}</h2>
      </div>
    {% endif %}

    <div class="best-offers-grid">
      {% for block in section.blocks %}
        {%- liquid
          assign image = block.settings.image
          assign card_link = block.settings.card_link
        -%}

        {%- case block.type -%}

          {%- when 'feature_card' -%}
            <a
              href="{{ card_link | default: '#' }}"
              class="bo-card bo-card--feature"
              data-fade-in
              style="--text-color: {{ block.settings.text_color }};--overlay-opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"
              {{ block.shopify_attributes }}
            >
              <span class="bo-card-bg">
                {%- if image != blank -%}
                  {{
                    image
                    | image_url: width: 1200
                    | image_tag:
                      loading: 'lazy',
                      width: image.width,
                      height: image.height,
                      class: 'lazyload',
                      alt: block.settings.title | default: image.alt | escape
                  }}
                {%- else -%}
                  {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                {%- endif -%}
              </span>
              <span class="bo-card-overlay"></span>

              {% if block.settings.badge_text != '' %}
                <span
                  class="bo-badge bo-badge--corner"
                  style="--badge-bg: {{ block.settings.badge_bg }};--badge-color: {{ block.settings.badge_text_color }};"
                >
                  {% if block.settings.badge_icon != '' %}<i class="{{ block.settings.badge_icon }}"></i>{% endif %}
                  {{ block.settings.badge_text }}
                </span>
              {% endif %}

              {% if block.settings.price != '' %}
                <span
                  class="bo-price-tag"
                  style="--tag-bg: {{ block.settings.price_tag_bg }};--tag-color: {{ block.settings.price_tag_color }};"
                >
                  {% if block.settings.discount_label != '' %}
                    <span class="bo-price-discount">{{ block.settings.discount_label }}</span>
                  {% endif %}
                  {% if block.settings.compare_price != '' %}
                    <span class="bo-price-compare">{{ block.settings.compare_price }}</span>
                  {% endif %}
                  <span class="bo-price-now">{{ block.settings.price }}</span>
                </span>
              {% endif %}

              <span class="bo-card-inner">
                {% if block.settings.title != '' %}
                  <span class="bo-card-title">{{ block.settings.title }}</span>
                {% endif %}
                {% if block.settings.subtitle != '' %}
                  <span class="bo-card-subtitle">{{ block.settings.subtitle }}</span>
                {% endif %}

                <span class="bo-card-actions">
                  {% if block.settings.coupon_code != '' %}
                    <span class="bo-coupon" data-coupon="{{ block.settings.coupon_code }}">
                      <span class="bo-coupon-code">{{ block.settings.coupon_code }}</span>
                      <button type="button" class="bo-coupon-copy" aria-label="Copy code">
                        <i class="feather-copy"></i>
                      </button>
                    </span>
                  {% endif %}
                  {% if block.settings.button_label != '' %}
                    <span
                      class="bo-btn"
                      style="--btn-bg: {{ block.settings.button_bg }};--btn-color: {{ block.settings.button_text_color }};"
                    >
                      {{ block.settings.button_label }}
                    </span>
                  {% endif %}
                </span>
              </span>
            </a>

          {%- when 'small_card' -%}
            <a
              href="{{ card_link | default: '#' }}"
              class="bo-card bo-card--small"
              data-fade-in
              style="--text-color: {{ block.settings.text_color }};--card-bg: {{ block.settings.card_bg }};--overlay-opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"
              {{ block.shopify_attributes }}
            >
              <span class="bo-card-bg">
                {%- if image != blank -%}
                  {{
                    image
                    | image_url: width: 700
                    | image_tag:
                      loading: 'lazy',
                      width: image.width,
                      height: image.height,
                      class: 'lazyload',
                      alt: block.settings.title | default: image.alt | escape
                  }}
                {%- endif -%}
              </span>
              <span class="bo-card-overlay"></span>

              {% if block.settings.badge_text != '' %}
                <span
                  class="bo-badge bo-badge--corner"
                  style="--badge-bg: {{ block.settings.badge_bg }};--badge-color: {{ block.settings.badge_text_color }};"
                >
                  {% if block.settings.badge_icon != '' %}<i class="{{ block.settings.badge_icon }}"></i>{% endif %}
                  {{ block.settings.badge_text }}
                </span>
              {% endif %}

              <span class="bo-card-inner">
                {% if block.settings.title != '' %}
                  <span class="bo-card-title">{{ block.settings.title }}</span>
                {% endif %}
              </span>
            </a>

          {%- when 'wide_card' -%}
            <a
              href="{{ card_link | default: '#' }}"
              class="bo-card bo-card--wide"
              data-fade-in
              style="--text-color: {{ block.settings.text_color }};--card-bg: {{ block.settings.card_bg }};--overlay-opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"
              {{ block.shopify_attributes }}
            >
              <span class="bo-card-overlay"></span>

              <span class="bo-card-inner bo-card-inner--wide">
                {% if block.settings.badge_text != '' %}
                  <span
                    class="bo-badge bo-badge--inline"
                    style="--badge-bg: {{ block.settings.badge_bg }};--badge-color: {{ block.settings.badge_text_color }};"
                  >
                    {{ block.settings.badge_text }}
                  </span>
                {% endif %}
                {% if block.settings.title != '' %}
                  <span class="bo-card-title bo-card-title--wide">{{ block.settings.title }}</span>
                {% endif %}
                {% if block.settings.subtitle != '' %}
                  <span class="bo-card-subtitle">{{ block.settings.subtitle }}</span>
                {% endif %}
                {% if block.settings.button_label != '' %}
                  <span
                    class="bo-btn"
                    style="--btn-bg: {{ block.settings.button_bg }};--btn-color: {{ block.settings.button_text_color }};"
                  >
                    {{ block.settings.button_label }}
                  </span>
                {% endif %}
              </span>

              <span class="bo-card-media">
                {%- if image != blank -%}
                  {{
                    image
                    | image_url: width: 700
                    | image_tag:
                      loading: 'lazy',
                      width: image.width,
                      height: image.height,
                      class: 'lazyload',
                      alt: block.settings.title | default: image.alt | escape
                  }}
                {%- endif -%}
              </span>
            </a>

        {%- endcase -%}
      {% endfor %}
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.querySelector('.best-offers-{{ section.id }}');
    if (!root) return;
    root.addEventListener('click', function (e) {
      var btn = e.target.closest('.bo-coupon-copy');
      if (!btn) return;
      e.preventDefault();
      var wrap = btn.closest('.bo-coupon');
      var code = wrap ? wrap.getAttribute('data-coupon') : '';
      if (!code) return;
      var done = function () {
        wrap.classList.add('is-copied');
        setTimeout(function () { wrap.classList.remove('is-copied'); }, 1500);
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(code).then(done).catch(function () {});
      } else {
        var ta = document.createElement('textarea');
        ta.value = code;
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); done(); } catch (err) {}
        document.body.removeChild(ta);
      }
    });
  })();
</script>

