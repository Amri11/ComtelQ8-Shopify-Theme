{{ 'reels-video.css' | asset_url | stylesheet_tag }}
<section
  class="reels-slider"
  style="--padding-top: {{ section.settings.section_padding_top }}px; --padding-bottom: {{ section.settings.section_padding_bottom }}px; --padding-top-xs: {{ section.settings.section_padding_top_xs }}px; --padding-bottom-xs: {{ section.settings.section_padding_bottom_xs }}px; --background-color: {{ section.settings.section_bgcolor }};"
>
  <div class="{% if section.settings.container == 'fluid' %}container-fluid{% else %}container{% endif %}">
    <div class="row">
      <div class="col">
        {% if section.settings.section_heading != '' or section.settings.section_subheading != '' %}
          <div class="section-capture">
            <div class="section-title">
            {% if section.settings.section_subheading != '' %}
                <span data-fade-in class="sub-title">{{ section.settings.section_subheading }}</span>
              {% endif %}
              {% if section.settings.section_heading != '' %}
                <h2 class="mr-0" data-fade-in>{{ section.settings.section_heading }}</h2>
              {% endif %}
            </div>
          </div>
        {% endif %}
        <div class="swiper" id="reel-slider-{{ section.id }}">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              <div class="swiper-slide" {{ block.shopify_attributes }}>
                <div class="reel-video">
                  {% if block.settings.video != blank %}
                    <div class="reel-video-wrapper">
                      {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
                    </div>
                  {% endif %}
                  {% assign product = all_products[block.settings.product] %}
                  {% if product %}
                    <div class="single-product">
                      {% render 'reels-product', product: product %}
                    </div>
                  {% else %}
                    <p class="text-gray-500">Selected product not found.</p>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
          {% if section.settings.arrow_enable %}
          <div class="slider-arrow">
            <button class="arrow-prev arrow-prev-{{ section.id }}" aria-label="arrow"><i class="feather-arrow-left"></i></button>
            <button class="arrow-next arrow-next-{{ section.id }}" aria-label="arrow"><i class="feather-arrow-right"></i></button>
          </div>
          {% endif %} 
          {% if section.settings.dots_enable %}
          <div class="slider-dot slider-dot-{{ section.id }}"></div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
addEventListener('DOMContentLoaded', (event) => { 
  var swiper = new Swiper('#reel-slider-{{ section.id }}', {
    slidesPerView: {{ section.settings.slider_item_desktop }},
    loop: false,
    spaceBetween: 30,
    {%- if request.locale.iso_code == 'ar' -%}
    rtl: true,
    {%- endif -%}
    observer: true,
    observeParents: true,
    watchSlidesProgress: true,
    {% if section.settings.slider_autoplay_enable %}
    autoplay: {
      delay: {{ section.settings.slider_autoplay_timeout }},
      disableOnInteraction: false,
      pauseOnMouseEnter: true
    },
    speed: {{ section.settings.slider_autoplay_speed }},
    {% endif %}
    {% if section.settings.arrow_enable %}
    navigation: {
      nextEl: ".arrow-next-{{ section.id }}",
      prevEl: ".arrow-prev-{{ section.id }}",
    },
    {% endif %}
    {% if section.settings.dots_enable %}
    pagination: {
      el: ".slider-dot-{{ section.id }}",
      clickable: true
    },
    {% endif %}
    speed: 1000,
    breakpoints: {
      0: {
        slidesPerView: 1,
        grid: {
          rows: 1,
          fill: 'row' | 'column',
        },
        spaceBetween: 12
      },
      320: {
        slidesPerView: {{ section.settings.slider_item_mobile }},
        grid: {
          rows: 1,
          fill: 'row' | 'column',
        },
        spaceBetween: 12
      },
      360: {
        slidesPerView: {{ section.settings.slider_item_mobile }},
        grid: {
          rows: 1,
          fill: 'row' | 'column',
        },
        spaceBetween: 12
      },
      540: {
        slidesPerView: {{ section.settings.slider_item_tablet }},
        grid: {
          rows: 1,
          fill: 'row' | 'column',
        },
        spaceBetween: 12
      },
      640: {
        slidesPerView: {{ section.settings.slider_item_ipadpro }},
        grid: {
          rows: 1,
          fill: 'row' | 'column',
        },
        spaceBetween: 12
      },
      768: {
        slidesPerView: {{ section.settings.slider_item_ipadpro }},
        grid: {
          rows: 1,
          fill: 'row' | 'column',
        },
        spaceBetween: 30,
      },
      1024: {
        slidesPerView: {{ section.settings.slider_item_ipadpro }},
        grid: {
          rows: 1,
          fill: 'row' | 'column',
        },
        spaceBetween: 30,
      },
      1199: {
        slidesPerView: {{ section.settings.slider_item_laptop }},
        grid: {
          rows: 1,
          fill: 'row' | 'column',
        },
        spaceBetween: 30,
      },
      1299: {
        slidesPerView: {{ section.settings.slider_item_laptop }},
        grid: {
          rows: 1,
          fill: 'row' | 'column',
        },
        spaceBetween: 30,
      },
      1399: {
        slidesPerView: {{ section.settings.slider_item_desktop }},
        grid: {
          rows: 1,
          fill: 'row' | 'column',
        },
        spaceBetween: 30,
      },
      1499: {
        slidesPerView: {{ section.settings.slider_item_desktop }},
        grid: {
          rows: 1,
          fill: 'row' | 'column',
        },
        spaceBetween: 30,
      }
    }
  });
});
</script>


