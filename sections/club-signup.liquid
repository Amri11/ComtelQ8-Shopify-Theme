{{ 'club-signup.css' | asset_url | stylesheet_tag }}
<section
  class="club-signup"
  style="--padding-top: {{ section.settings.section_padding_top }}px;--padding-bottom: {{ section.settings.section_padding_bottom }}px;--padding-top-xs: {{ section.settings.section_padding_top_xs }}px;--padding-bottom-xs: {{ section.settings.section_padding_bottom_xs }}px;--block-bg-color: {{ section.settings.block_bg_color }};--heading-color: {{ section.settings.heading_color }};--text-color: {{ section.settings.text_color }};--btn-bg-color: {{ section.settings.btn_bg_color }};--btn-text-color: {{ section.settings.btn_text_color }};--radius: {{ section.settings.block_radius }}px;"
>
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    <div class="club-signup-block" data-fade-in>
      <div class="club-signup-content">
        {%- if section.settings.logo != blank -%}
          <div class="club-signup-logo">
            {{
              section.settings.logo
              | image_url: width: 320
              | image_tag:
                loading: 'lazy',
                width: section.settings.logo.width,
                height: section.settings.logo.height,
                class: 'lazyload',
                alt: section.settings.heading | default: shop.name
            }}
          </div>
        {%- endif -%}

        {%- if section.settings.heading != '' -%}
          <h2 class="club-signup-heading mr-0">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {% form 'customer' %}
          {{ form.errors | default_errors }}
          {% if form.posted_successfully? %}
            <p class="mr-0 text-success">
              <span>{{ 'general.newsletter_form.confirmation' | t }}</span>
            </p>
          {% endif %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="club-signup-field">
            <label for="ClubEmail-{{ section.id }}" class="hidden">
              {{ 'general.newsletter_form.newsletter_email' | t }}
            </label>
            <input
              type="email"
              name="contact[email]"
              class="club-signup-input"
              id="ClubEmail-{{ section.id }}"
              value="{% if customer %}{{ customer.email }}{% endif %}"
              placeholder="{{ section.settings.placeholder | default: 'E-mail' }}"
              autocapitalize="off"
              autocomplete="email"
              required
            >
            <button
              class="club-signup-btn"
              type="submit"
              name="commit"
              aria-label="{{ section.settings.button_label | default: 'Sign Up' | escape }}"
            >
              {{ section.settings.button_label | default: 'Sign Up' }}
            </button>
          </div>
          {%- if form.errors -%}
            <small class="club-signup-error" id="ClubSignup-error--{{ section.id }}">
              {{- form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email -}}
            </small>
          {%- endif -%}
        {% endform %}

        {%- if section.settings.consent_text != blank -%}
          <div class="club-signup-consent rte">{{ section.settings.consent_text }}</div>
        {%- endif -%}
      </div>

      {%- if section.settings.image != blank -%}
        <div class="club-signup-media">
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              width: section.settings.image.width,
              height: section.settings.image.height,
              class: 'lazyload',
              alt: section.settings.heading | default: shop.name
          }}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Club Signup",
  "settings": [
    {
      "type": "header",
      "content": "Section width"
    },
    {
      "type": "select",
      "id": "container",
      "label": "Section width",
      "options": [
        { "label": "Full width", "value": "fluid" },
        { "label": "Contained", "value": "normal" }
      ],
      "default": "normal"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Optional. Recommended height: 40px"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the Club and Get 10% Off Your First Order!"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "E-mail"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Sign Up"
    },
    {
      "type": "richtext",
      "id": "consent_text",
      "label": "Consent text",
      "default": "<p>By clicking on the \"Sign Up\" button, I confirm my agreement with the <a href=\"/policies/privacy-policy\">Privacy Policy</a> and <a href=\"/policies/terms-of-service\">Terms of Use</a></p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Shown on the right. Recommended size: 1200x640px"
    },
    {
      "type": "header",
      "content": "Section space top bottom"
    },
    {
      "type": "paragraph",
      "content": "Desktop"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Space top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Space bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "paragraph",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "section_padding_top_xs",
      "label": "Space top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_bottom_xs",
      "label": "Space bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "block_bg_color",
      "label": "Block background",
      "default": "#F2F3F5"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#6B7280"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button background",
      "default": "#FCD307"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button text",
      "default": "#1A1A1A"
    },
    {
      "type": "range",
      "id": "block_radius",
      "label": "Block corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Club Signup"
    }
  ]
}
{% endschema %}
