<section
  class="logo-list"
  style="--padding-top: {{ section.settings.section_padding_top }}px;--padding-bottom: {{ section.settings.section_padding_bottom }}px; --padding-top-xs: {{ section.settings.section_padding_top_xs }}px;--padding-bottom-xs: {{ section.settings.section_padding_bottom_xs }}px;"
>
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    <div
      class="brand-logo swiper"
      id="brand-logo-{{ section.id }}"
      data-slides-per-view="{{ section.settings.slide_view }}"
    >
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.brand_url }}" aria-label="{{ block.settings.brand_image }}">
              {%- if block.settings.brand_image != blank -%}
                {{
                  block.settings.brand_image
                  | image_url: width: 500
                  | image_tag:
                    loading: 'lazy',
                    width: block.settings.brand_image.width,
                    height: block.settings.brand_image.height,
                    class: 'lazyload',
                    loading: 'lazy'
                }}
              {%- else -%}
                {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                {{ placeholder | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
              {%- endif -%}
            </a>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
<script type="text/javascript">
  addEventListener('DOMContentLoaded', (event) => {
    var swiper = new Swiper('#brand-logo-{{ section.id }}', {
      slidesPerView: {{ section.settings.slider_item_desktop }},
      spaceBetween: 30,
      grid: {
        rows: 1,
        fill: 'row' | 'column',
      },
      {%- if request.locale.iso_code == 'ar' -%}
      rtl: true,
      {%- endif -%}
      {% if section.settings.slider_autoplay_enable %}
      autoplay: {
        delay: {{ section.settings.slider_autoplay_timeout }},
        disableOnInteraction: false,
        pauseOnMouseEnter: true
      },
      speed: {{ section.settings.slider_autoplay_speed }},
      {% endif %}
      {% if section.settings.arrow_enable %}
      navigation: {
        nextEl: ".arrow-next-{{ section.id }}",
        prevEl: ".arrow-prev-{{ section.id }}",
      },
      {% endif %}
      {% if section.settings.dots_enable %}
      pagination: {
        el: ".slider-dot-{{ section.id }}",
        clickable: true
      },
      {% endif %}
      breakpoints: {
        0: {
          slidesPerView: 1,
          spaceBetween: 12
        },
        320: {
          slidesPerView: 1,
          spaceBetween: 12
        },
        360: {
          slidesPerView: 1,
          spaceBetween: 12
        },
        540: {
          slidesPerView: {{ section.settings.slider_item_mobile }},
          spaceBetween: 12
        },
        640: {
          slidesPerView: {{ section.settings.slider_item_tablet }},
          spaceBetween: 12
        },
        768: {
          slidesPerView: {{ section.settings.slider_item_tablet }},
          spaceBetween: 30,
        },
        1024: {
          slidesPerView: {{ section.settings.slider_item_ipad }},
          spaceBetween: 30
        },
        1199: {
          slidesPerView: {{ section.settings.slider_item_ipadpro }},
          spaceBetween: 30
        },
        1399: {
          slidesPerView: {{ section.settings.slider_item_desktop }},
          spaceBetween: 30
        },
        1499: {
          slidesPerView: {{ section.settings.slider_item_desktop }},
          spaceBetween: 30
        }
      }
    });
  });
</script>
