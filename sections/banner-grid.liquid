{{ 'banner-grid.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign columns = section.settings.columns | default: 3 | times: 1
  assign col_basis = 100.0 | divided_by: columns
-%}
<section class="banner-grid" style="--padding-top: {{ section.settings.section_padding_top }}px;--padding-bottom: {{ section.settings.section_padding_bottom }}px; --padding-top-xs: {{ section.settings.section_padding_top_xs }}px;--padding-bottom-xs: {{ section.settings.section_padding_bottom_xs }}px;--background-color: {{ section.settings.section_bg_color }};--col-basis: {{ col_basis }}%;">
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    <div class="row">
      <div class="col">
        <div class="grid-wrap">
          <ul class="list-unstyled banner-ul">
            {% for block in section.blocks %}
            {% case block.type %}
            {% when 'single_banner' %}
            <li class="banner-li single-banner" {{ block.shopify_attributes }}>
              <div class="banner-item">
                <div class="banner-main">
                  {%- if block.settings.banner_link != blank -%}<a href="{{ block.settings.banner_link }}" class="banner-media">{%- else -%}<div class="banner-media">{%- endif -%}
                    {%- if block.settings.banner_img != blank -%}
                      {{ block.settings.banner_img | image_url: width: 1080 | image_tag:
                      loading: 'lazy',
                      width: block.settings.banner_img.width,
                      height: block.settings.banner_img.height,
                      class: "img-fluid lazyload",
                      alt: block.settings.banner_img.alt | escape }}
                    {%- else -%}
                      {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                    {%- endif -%}
                  {%- if block.settings.banner_link != blank -%}</a>{%- else -%}</div>{%- endif -%}
                </div>
              </div>
            </li>
            {% when 'two_banner' %}
            <li class="banner-li two-banner" {{ block.shopify_attributes }}>
              <div class="banner-item">
                <div class="banner-main">
                  {%- if block.settings.two_banner_1_link != blank -%}<a href="{{ block.settings.two_banner_1_link }}" class="banner-media">{%- else -%}<div class="banner-media">{%- endif -%}
                    {%- if block.settings.two_banner_1_img != blank -%}
                      {{ block.settings.two_banner_1_img | image_url: width: 1080 | image_tag:
                      loading: 'lazy',
                      width: block.settings.two_banner_1_img.width,
                      height: block.settings.two_banner_1_img.height,
                      class: "img-fluid lazyload",
                      alt: block.settings.two_banner_1_img.alt | escape }}
                    {%- else -%}
                      {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                    {%- endif -%}
                  {%- if block.settings.two_banner_1_link != blank -%}</a>{%- else -%}</div>{%- endif -%}
                </div>
                <div class="banner-main">
                  {%- if block.settings.two_banner_2_link != blank -%}<a href="{{ block.settings.two_banner_2_link }}" class="banner-media">{%- else -%}<div class="banner-media">{%- endif -%}
                    {%- if block.settings.two_banner_2_img != blank -%}
                      {{ block.settings.two_banner_2_img | image_url: width: 1080 | image_tag:
                      loading: 'lazy',
                      width: block.settings.two_banner_2_img.width,
                      height: block.settings.two_banner_2_img.height,
                      class: "img-fluid lazyload",
                      alt: block.settings.two_banner_2_img.alt | escape }}
                    {%- else -%}
                      {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                    {%- endif -%}
                  {%- if block.settings.two_banner_2_link != blank -%}</a>{%- else -%}</div>{%- endif -%}
                </div>
              </div>
            </li>
            {% endcase %}
            {% endfor %}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Banner grid",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "info": "Number of columns across the row on desktop. Blocks are divided equally and wrap to the next row. Tablet shows 2 columns, mobile shows 1.",
      "options": [
        {
          "label": "1 column",
          "value": "1"
        },
        {
          "label": "2 columns",
          "value": "2"
        },
        {
          "label": "3 columns",
          "value": "3"
        },
        {
          "label": "4 columns",
          "value": "4"
        }
      ],
      "default": "3"
    },
    {
      "type": "header",
      "content": "Section width"
    },
    {
      "type": "select",
      "id": "container",
      "label": "Section width",
      "options": [
        {
          "label": "Fluid",
          "value": "fluid"
        },
        {
          "label": "Normal",
          "value": "normal"
        }
      ],
      "default": "fluid"
    },
    {
      "type": "header",
      "content": "Section space top bottom"
    },
    {
      "type": "paragraph",
      "content": "Desktop"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Space top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Space bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "paragraph",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "section_padding_top_xs",
      "label": "Space top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom_xs",
      "label": "Space bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Section background color"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "single_banner",
      "name": "Single banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "banner_img",
          "label": "Banner image",
          "info": "Recommended Size: 555x550px"
        },
        {
          "type": "url",
          "id": "banner_link",
          "label": "Banner link"
        }
      ]
    },
    {
      "type": "two_banner",
      "name": "Two banner",
      "settings": [
        {
          "type": "header",
          "content": "Banner 1"
        },
        {
          "type": "image_picker",
          "id": "two_banner_1_img",
          "label": "Banner image",
          "info": "Recommended Size: 555x260px"
        },
        {
          "type": "url",
          "id": "two_banner_1_link",
          "label": "Banner link"
        },
        {
          "type": "header",
          "content": "Banner 2"
        },
        {
          "type": "image_picker",
          "id": "two_banner_2_img",
          "label": "Banner image",
          "info": "Recommended Size: 555x260px"
        },
        {
          "type": "url",
          "id": "two_banner_2_link",
          "label": "Banner link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner grid",
      "blocks": [
        {
          "type": "single_banner"
        },
        {
          "type": "two_banner"
        },
        {
          "type": "single_banner"
        }
      ]
    }
  ]
}
{% endschema %}
