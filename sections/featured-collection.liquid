{% assign featured_tab_enable = section.settings.featured_tab_enable %}
<section
  class="featured-collection fe-coll-{{ section.id }}"
  style="--padding-top: {{ section.settings.section_padding_top }}px;--padding-bottom: {{ section.settings.section_padding_bottom }}px; --padding-top-xs: {{ section.settings.section_padding_top_xs }}px;--padding-bottom-xs: {{ section.settings.section_padding_bottom_xs }}px;--background-color: {{ section.settings.section_bg_color }};"
>
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    {% if section.settings.section_subheading != '' or section.settings.section_heading != '' %}
    <div class="section-capture {% if section.settings.countdown_enable %} deal-counter {% endif %}">
      <div class="section-title">
        {% if section.settings.section_subheading != '' %}
          <span data-fade-in class="sub-title">{{ section.settings.section_subheading }}</span>
        {% endif %}
        {% if section.settings.section_heading != '' %}
          <h2 class="mr-0" data-fade-in>{{ section.settings.section_heading }}</h2>
        {% endif %}
      </div>
      {% if section.settings.countdown_enable %}
      <ul data-fade-in class="contdown_row list-unstyled">
        <li class="countdown_section">
          <span id="days-{{ section.id }}" class="countdown_timer"></span>
          <span class="countdown_title">{{ settings.day_title }}</span>
        </li>
        <li class="countdown_section">
          <span id="hours-{{ section.id }}" class="countdown_timer"></span>
          <span class="countdown_title">{{ settings.hour_title }}</span>
        </li>
        <li class="countdown_section">
          <span id="minutes-{{ section.id }}" class="countdown_timer"></span>
          <span class="countdown_title">{{ settings.minute_title }}</span>
        </li>
        <li class="countdown_section">
          <span id="seconds-{{ section.id }}" class="countdown_timer"></span>
          <span class="countdown_title">{{ settings.second_title }}</span>
        </li>
      </ul>
      {% endif %}
      {%- if featured_tab_enable -%}
      <ul class="nav nav-tabs" role="tablist">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'product_tab' %}
              {% assign category_product = collections[block.settings.tab_product] %}
              <li role="presentation" data-fade-in>
                <a
                  class="{% if forloop.first == true %}active show{% endif %}"
                  role="tab"
                  data-bs-toggle="tab"
                  href="#tab-{{ block.id }}">
                  {%- if block.settings.tab_img != blank -%}
                  {{
                    block.settings.tab_img
                    | image_url: width: 500
                    | image_tag:
                      loading: 'lazy',
                      width: block.settings.tab_img.width,
                      height: block.settings.tab_img.height,
                      class: 'lazyload desk-img',
                      alt: block.settings.tab_img.alt
                    | escape
                  }}
                  {%- endif -%}
                  {{- category_product.title | default: 'Collection' -}}
                </a>
              </li>
          {% endcase %}
        {% endfor %}
      </ul>
      {% endif %}
    </div>
    {% endif %}
    <div class="collection-wrap">
      {%- if featured_tab_enable -%}
      <div class="tab-content tabs">
      {% endif %}
        {% for block in section.blocks %}
        {% case block.type %}
        {% when 'product_tab' %}
        {% assign category_product = collections[block.settings.tab_product] %}
        {%- if featured_tab_enable -%}
        <div class="tab-pane fade{% if forloop.first == true %} active show{% endif %}" id="tab-{{ block.id }}" role="tabpanel">
        {%- endif -%}
          <div class="special-slider swiper" id="pro-{{ block.id }}" data-slides-per-view="{{ section.settings.product_view }}">
            <div class="swiper-wrapper">
              {% assign product_limit = section.settings.product_limit %}
              {% for product in category_product.products limit: product_limit %}
              <div class="swiper-slide">
                {%- liquid
                  if section.settings.category_special_product_view == 'grid'
                    render 'product-grid-item', product: product
                  elsif section.settings.category_special_product_view == 'list'
                    render 'product-grid-list', product: product
                  endif
                -%}
              </div>
              {% else %}
              {% for i in (1..product_limit) %}
              <div class="swiper-slide">
                {% if section.settings.category_special_product_view == 'list' %}
                <div class="product-grid-list">
                {% endif %}
                  <div class="single-product-wrap">
                    <div class="product-image">
                      {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                      {{ placeholder | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                    </div>
                    <div class="product-content">
                      <div class="product-title">
                        <h6 class="mr-0">
                          <a>{{ 'homepage.sections.product_title' | t }}</a>
                        </h6>
                      </div>
                      <div class="price-box">
                        <span class="new-price">{{ 'homepage.sections.product_price' | t }}</span>
                      </div>
                    </div>
                  </div>
                  {% if section.settings.category_special_product_view == 'list' %}
                </div>
                {% endif %}
              </div>
              {% endfor %}
              {% endfor %}
            </div>
            {% if section.settings.arrow_enable %}
            <div class="slider-arrow">
              <button class="arrow-prev arrow-prev-{{ section.id }}" aria-label="arrow"><i class="feather-arrow-left"></i></button>
              <button class="arrow-next arrow-next-{{ section.id }}" aria-label="arrow"><i class="feather-arrow-right"></i></button>
            </div>
            {% endif %} 
            {% if section.settings.dots_enable %}
            <div class="slider-dot slider-dot-{{ section.id }}"></div>
            {% endif %}
            {% if section.settings.view_btn != blank %}
            <div class="view-collection">
              <a class="btn-style" href="{{ category_product.url }}">
                {{ section.settings.view_btn }}
              </a>
            </div>
            {% endif %}
          </div>
        {%- if featured_tab_enable -%}
        </div>
        {% endif %}
        {% endcase %}
        <script type="text/javascript">
          addEventListener('DOMContentLoaded', (event) => {
            var swiper = new Swiper('#pro-{{ block.id }}', {
              slidesPerView: {{ section.settings.product_view }},
              grid: {
                rows: {{ section.settings.category_special_product_col }},
                fill: 'row' | 'column',
              },
              spaceBetween: 30,
              observer: true,
              observeParents: true,
              watchSlidesProgress: true,
              {%- if request.locale.iso_code == 'ar' -%}
              rtl: true,
              {%- endif -%}
              {% if section.settings.arrow_enable %}
              navigation: {
                nextEl: ".arrow-next-{{ section.id }}",
                prevEl: ".arrow-prev-{{ section.id }}",
              },
              {% endif %}
              {% if section.settings.dots_enable %}
              pagination: {
                el: ".slider-dot-{{ section.id }}",
                clickable: true
              },
              {% endif %}
              {% if section.settings.slider_autoplay_enable %}
              autoplay: {
                delay: {{ section.settings.slider_autoplay_timeout }},
                disableOnInteraction: false,
                pauseOnMouseEnter: true
              },
              speed: {{ section.settings.slider_autoplay_speed }},
              {% endif %}
              breakpoints: {
                0: {
                  slidesPerView: 1,
                  grid: {
                    rows: {{ section.settings.category_special_product_col }},
                    fill: 'row' | 'column',
                  },
                  spaceBetween: 12
                },
                320: {
                  slidesPerView: 1,
                  grid: {
                    rows: {{ section.settings.category_special_product_col }},
                    fill: 'row' | 'column',
                  },
                  spaceBetween: 12
                },
                360: {
                  slidesPerView: {{ section.settings.product_view_xs }},
                  grid: {
                    rows: {{ section.settings.category_special_product_col }},
                    fill: 'row' | 'column',
                  },
                  spaceBetween: 12
                },
                540: {
                  slidesPerView: {{ section.settings.product_view_xs }},
                  grid: {
                    rows: {{ section.settings.category_special_product_col }},
                    fill: 'row' | 'column',
                  },
                  spaceBetween: 12
                },
                640: {
                  slidesPerView: {{ section.settings.product_view_xs }},
                  grid: {
                    rows: {{ section.settings.category_special_product_col }},
                    fill: 'row' | 'column',
                  },
                  spaceBetween: 12
                },
                768: {
                  slidesPerView: {{ section.settings.product_view_xs }},
                  grid: {
                    rows: {{ section.settings.category_special_product_col }},
                    fill: 'row' | 'column',
                  },
                  spaceBetween: 30
                },
                1024: {
                  slidesPerView: {{ section.settings.product_view_sm }},
                  grid: {
                    rows: {{ section.settings.category_special_product_col }},
                    fill: 'row' | 'column',
                  },
                  spaceBetween: 30
                },
                1199: {
                  slidesPerView: {{ section.settings.product_view_sm }},
                  grid: {
                    rows: {{ section.settings.category_special_product_col }},
                    fill: 'row' | 'column',
                  },
                  spaceBetween: 30
                },
                1299: {
                  slidesPerView: {{ section.settings.product_view_lg }},
                  grid: {
                    rows: {{ section.settings.category_special_product_col }},
                    fill: 'row' | 'column',
                  },
                  spaceBetween: 30
                },
                1399: {
                  slidesPerView: {{ section.settings.product_view_lg }},
                  grid: {
                    rows: {{ section.settings.category_special_product_col }},
                    fill: 'row' | 'column',
                  },
                  spaceBetween: 30
                },
                1499: {
                  slidesPerView: {{ section.settings.product_view }},
                  grid: {
                    rows: {{ section.settings.category_special_product_col }},
                    fill: 'row' | 'column',
                  },
                  spaceBetween: 30
                }
              }
            });
            {% if section.settings.countdown_enable %}
            const second = 1000,
            minute = second * 60,
            hour = minute * 60,
            day = hour * 24;
            let countDown = new Date('{{ section.settings.product_month }} {{ section.settings.product_date }}, {{ section.settings.product_year }} 00:00:00').getTime(),
            x = setInterval(function() {
              let now = new Date().getTime(),
              distance = countDown - now;
              document.getElementById('days-{{ section.id }}').innerText = Math.floor(distance / (day)),
              document.getElementById('hours-{{ section.id }}').innerText = Math.floor((distance % (day)) / (hour)),
              document.getElementById('minutes-{{ section.id }}').innerText = Math.floor((distance % (hour)) / (minute)),
              document.getElementById('seconds-{{ section.id }}').innerText = Math.floor((distance % (minute)) / second);
            }, second)
            {% endif %}
          });
        </script>
        {% endfor %}
      {%- if featured_tab_enable -%}
      </div>
      {% endif %}
    </div>
  </div>
</section>
