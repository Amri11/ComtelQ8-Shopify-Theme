{{ 'offer-cards.css' | asset_url | stylesheet_tag }}
<section
  class="offer-cards"
  style="--padding-top: {{ section.settings.section_padding_top }}px;--padding-bottom: {{ section.settings.section_padding_bottom }}px; --padding-top-xs: {{ section.settings.section_padding_top_xs }}px;--padding-bottom-xs: {{ section.settings.section_padding_bottom_xs }}px;--background-color: {{ section.settings.section_bg_color }};--card-radius: {{ section.settings.card_radius }}px;"
>
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    {% if section.settings.section_heading != '' or section.settings.section_subheading != '' %}
      <div class="section-capture">
        <div class="section-title">
          {% if section.settings.section_heading != '' %}
            <h2 class="mr-0" data-fade-in>{{ section.settings.section_heading }}</h2>
          {% endif %}
          {% if section.settings.section_subheading != '' %}
            <span data-fade-in class="sub-title">{{ section.settings.section_subheading }}</span>
          {% endif %}
        </div>
      </div>
    {% endif %}
    <div class="offer-cards-wrap">
      <div class="swiper" id="offer-cards-{{ section.id }}">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="swiper-slide" {{ block.shopify_attributes }}>
              <a
                href="{{ block.settings.card_link | default: '#' }}"
                class="offer-card"
                data-fade-in
              >
                <span class="offer-card-image">
                  {%- if block.settings.card_image != blank -%}
                    {{
                      block.settings.card_image
                      | image_url: width: 720
                      | image_tag:
                        loading: 'lazy',
                        width: block.settings.card_image.width,
                        height: block.settings.card_image.height,
                        class: 'lazyload',
                        alt: block.settings.card_title | default: block.settings.card_image.alt
                      | escape
                    }}
                  {%- else -%}
                    {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                    {{ placeholder | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                  {%- endif -%}
                </span>

                {% if block.settings.badge_text != '' %}
                  <span
                    class="offer-card-badge"
                    style="--badge-bg: {{ block.settings.badge_bg_color }};--badge-color: {{ block.settings.badge_text_color }};"
                  >
                    {{ block.settings.badge_text }}
                  </span>
                {% endif %}

                {% if block.settings.card_title != '' %}
                  <span
                    class="offer-card-title"
                    style="color: {{ block.settings.card_title_color }};"
                  >
                    {{ block.settings.card_title }}
                  </span>
                {% endif %}
              </a>
            </div>
          {% endfor %}
        </div>

        {% if section.settings.arrow_enable %}
          <div class="slider-arrow offer-cards-arrow">
            <button class="arrow-prev arrow-prev-{{ section.id }}" aria-label="Previous"><i class="feather-chevron-left"></i></button>
            <button class="arrow-next arrow-next-{{ section.id }}" aria-label="Next"><i class="feather-chevron-right"></i></button>
          </div>
        {% endif %}
        {% if section.settings.dots_enable %}
          <div class="slider-dot slider-dot-{{ section.id }}"></div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<script type="text/javascript">
  addEventListener('DOMContentLoaded', (event) => {
    var swiper = new Swiper('#offer-cards-{{ section.id }}', {
      slidesPerView: {{ section.settings.slider_item_desktop }},
      spaceBetween: 16,
      loop: {{ section.settings.slider_loop }},
      watchOverflow: true,
      {% if section.settings.slider_autoplay_enable %}
      autoplay: {
        delay: {{ section.settings.slider_autoplay_timeout }},
        disableOnInteraction: false,
        pauseOnMouseEnter: true
      },
      speed: {{ section.settings.slider_autoplay_speed }},
      {% endif %}
      {% if section.settings.arrow_enable %}
      navigation: {
        nextEl: ".arrow-next-{{ section.id }}",
        prevEl: ".arrow-prev-{{ section.id }}",
      },
      {% endif %}
      {% if section.settings.dots_enable %}
      pagination: {
        el: ".slider-dot-{{ section.id }}",
        clickable: true
      },
      {% endif %}
      breakpoints: {
        0: {
          slidesPerView: {{ section.settings.slider_item_mobile }},
          spaceBetween: 12
        },
        540: {
          slidesPerView: {{ section.settings.slider_item_ipad }},
          spaceBetween: 12
        },
        768: {
          slidesPerView: {{ section.settings.slider_item_ipad }},
          spaceBetween: 16
        },
        1024: {
          slidesPerView: {{ section.settings.slider_item_ipadpro }},
          spaceBetween: 16
        },
        1199: {
          slidesPerView: {{ section.settings.slider_item_desktop }},
          spaceBetween: 16
        }
      }
    });
  });
</script>

{% schema %}
{
  "name": "Offer cards",
  "settings": [
    {
      "type": "header",
      "content": "Section width"
    },
    {
      "type": "select",
      "id": "container",
