{{ 'instagram.css' | asset_url | stylesheet_tag }}
<section
  class="instagram-warp"
  style="--padding-top: {{ section.settings.section_padding_top }}px;--padding-bottom: {{ section.settings.section_padding_bottom }}px; --padding-top-xs: {{ section.settings.section_padding_top_xs }}px;--padding-bottom-xs: {{ section.settings.section_padding_bottom_xs }}px; --background-color: {{ section.settings.section_background_color }};"
>
  <div class="{% if section.settings.border_width == 'full' %}container-full{% elsif section.settings.border_width == 'fluid' %}container-fluid{% else %}container{% endif %}">
    {% if section.settings.section_subheading != '' or section.settings.section_heading != '' %}
    <div class="section-capture">
      <div class="section-title">
        {% if section.settings.section_subheading != '' %}
        <span data-fade-in class="sub-title">{{ section.settings.section_subheading }}</span>
        {% endif %}
        {% if section.settings.section_heading != '' %}
        <h2 class="mr-0" data-fade-in>{{ section.settings.section_heading }}</h2>
        {% endif %}
      </div>
    </div>
    {% endif %}
    <div class="instagram-main" data-slides-per-view="5">
      <div class="swiper" id="instagram-{{ section.id }}">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
          <div class="swiper-slide">
            <div class="insta-item">
              <a class="banner-hover insta-image" href="{{ block.settings.insta_url }}">
                {%- if block.settings.insta_img != blank -%}
                  {{
                    block.settings.insta_img
                    | image_url: width: 1024
                    | image_tag:
                      loading: 'lazy',
                      width: block.settings.insta_img.width,
                      height: block.settings.insta_img.height,
                      class: 'lazyload',
                      alt: block.settings.insta_img.alt
                    | escape
                  }}
                {%- else -%}
                  {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                  {{ placeholder | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                {%- endif -%}
              </a>
              <div class="insta-content">
                <span class="icon"><i class="ri-instagram-line"></i></span>
              </div>
            </div>
          </div>
          {% endfor %}
        </div>
        {% if section.settings.arrow_enable %}
        <div class="slider-arrow">
          <button class="arrow-prev arrow-prev-{{ section.id }}" aria-label="arrow"><i class="feather-arrow-left"></i></button>
          <button class="arrow-next arrow-next-{{ section.id }}" aria-label="arrow"><i class="feather-arrow-right"></i></button>
        </div>
        {% endif %} 
        {% if section.settings.dots_enable %}
        <div class="slider-dot slider-dot-{{ section.id }}"></div>
        {% endif %}
      </div>
    </div>
  </div>
</section>
<script type="text/javascript">
  addEventListener('DOMContentLoaded', (event) => {
    var swiper = new Swiper('#instagram-{{ section.id }}', {
      slidesPerView: {{ section.settings.slider_item_desktop }},
      spaceBetween: 30,
      grid: {
        rows: 1,
        fill: 'row' | 'column',
      },
      {%- if request.locale.iso_code == 'ar' -%}
      rtl: true,
      {%- endif -%}
      loop: true,
      observer: true,
      observeParents: true,
      watchSlidesProgress: true,
      {% if section.settings.slider_autoplay_enable %}
      autoplay: {
        delay: {{ section.settings.slider_autoplay_timeout }},
        disableOnInteraction: false,
        pauseOnMouseEnter: true
      },
      speed: {{ section.settings.slider_autoplay_speed }},
      {% endif %}
      {% if section.settings.arrow_enable %}
      navigation: {
        nextEl: ".arrow-next-{{ section.id }}",
        prevEl: ".arrow-prev-{{ section.id }}",
      },
      {% endif %}
      {% if section.settings.dots_enable %}
      pagination: {
        el: ".slider-dot-{{ section.id }}",
        clickable: true
      },
      {% endif %}
      breakpoints: {
        0: {
          slidesPerView: 1,
          spaceBetween: 12
        },
        320: {
          slidesPerView: {{ section.settings.slider_item_mobile }},
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        360: {
          slidesPerView: {{ section.settings.slider_item_mobile }},
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        540: {
          slidesPerView: {{ section.settings.slider_item_tablet }},
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        640: {
          slidesPerView: {{ section.settings.slider_item_tablet }},
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        768: {
          slidesPerView: {{ section.settings.slider_item_tablet }},
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 30
        },
        1024: {
          slidesPerView: {{ section.settings.slider_item_ipadpro }},
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 30
        },
        1199: {
          slidesPerView: {{ section.settings.slider_item_laptop }},
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 30
        },
        1499: {
          slidesPerView: {{ section.settings.slider_item_desktop }},
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 30
        }
      }
    });

    $('.st-btn').on('click', function(){
      $(this).parent('.st-hotspot').toggleClass("open").siblings().removeClass("open");
    });
  });
</script>
{% schema %}
{
