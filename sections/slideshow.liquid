{{ 'slideshow.css' | asset_url | stylesheet_tag }}
<section class="slider-content">
  <div class="home-slider swiper" id="home-slider-{{ section.id }}">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        <div class="swiper-slide slide-{{ block.id }}" {{ block.shopify_attributes }}>
          <div class="slide-image">
            <a href="{{ block.settings.slider_button_1_url }}" title="{{ block.settings.slider_button }}">
              {%- if block.settings.slider_video_enable -%}
                {%- if block.settings.video != blank -%}
                {{
                  block.settings.video
                  | video_tag:
                    image_size: '1100x',
                    autoplay: true,
                    loop: block.settings.enable_video_looping,
                    controls: false,
                    muted: true,
                    id: 'slider-video',
                    loading: 'lazy'
                }}
                {%- else -%}
                {%- capture placeholder -%}hero-apparel-{% cycle 1, 2, 3 %}{%- endcapture -%}
                {{ placeholder | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              {%- else -%}
                {%- if block.settings.slider_img != blank -%}
                  {% assign image_height = block.settings.slider_img.width
                    | divided_by: block.settings.slider_img.aspect_ratio
                  %}
                  {{
                    block.settings.slider_img
                    | image_url: width: 3840
                    | image_tag:
                      width: block.settings.slider_img.width,
                      height: image_height,
                      class: 'lazyload desk-img',
                      loading: 'lazy'
                  }}
                {%- else -%}
                  {%- capture placeholder -%}hero-apparel-{% cycle 1, 2, 3 %}{%- endcapture -%}
                  {{ placeholder | placeholder_svg_tag: 'placeholder-svg desk-img' }}
                {%- endif -%}
                
                {%- if block.settings.slider_mobile_img != blank -%}
                  {% assign image_height = block.settings.slider_mobile_img.width 
                    | divided_by: block.settings.slider_mobile_img.aspect_ratio
                  %}
                  {{
                    block.settings.slider_mobile_img
                    | image_url: width: 600
                    | image_tag:
                      width: block.settings.slider_mobile_img.width,
                      height: image_height,
                      class: 'lazyload mobile-img',
                      loading: 'lazy'
                  }}
                {%- else -%}
                  {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3 %}{%- endcapture -%}
                  {{ placeholder | placeholder_svg_tag: 'placeholder-svg mobile-img' }}
                {%- endif -%}
              {%- endif -%}
            </a>
            <div class="container-fluid slider-info-content {% if block.settings.mobile_text_enable %} sm-dnone{% endif %}">
              <div class="slider-text-info {% if block.settings.slider_content_position == "right" %} slider-content-right{% elsif block.settings.slider_content_position == "left" %} slider-content-left{% else %} slider-content-center{% endif %}{% if block.settings.slider_text_position == "right" %} slider-text-right{% elsif block.settings.slider_text_position == "left" %} slider-text-left{% else %} slider-text-center{% endif %}">
                {% if block.settings.slider_desc != '' %}
                  <span class="sub-title" style="color:{{ block.settings.slider_desc_color }};">
                    {{- block.settings.slider_desc -}}
                  </span>
                {% endif %}
                {% if block.settings.slider_title != '' %}
                  <h2 class="m-0" style="color:{{ block.settings.slider_title_color }};">
                    {{ block.settings.slider_title }}
                  </h2>
                {% endif %}
                <div class="slider-button">
                  {% if block.settings.slider_button_1 != '' %}
                  <a href="{{ block.settings.slider_button_1_url }}" class="btn-style text-btn btn-1" title="{{- block.settings.slider_button_1 }}" style="--btn1-txt-color: {{ block.settings.btn_1_txt_color }}; --btn1-txt-hvr-color: {{ block.settings.btn_1_txt_hvr_color }}; --btn1-bg-color: {{ block.settings.btn_1_bg_color }}; --btn1-bg-hvr-color: {{ block.settings.btn_1_bg_hvr_color }};  --btn1-border-color: {{ block.settings.btn_1_border_color }}; --btn1-border-hvr-color: {{ block.settings.btn_1_border_hvr_color }};">
                    {{- block.settings.slider_button_1 }}
                  </a>
                  {% endif %}
                  {% if block.settings.slider_button_2 != '' %}
                  <a href="{{ block.settings.slider_button_2_url }}" class="btn-style3 text-btn btn-2" title="{{- block.settings.slider_button_2 }}" style="--btn2-txt-color: {{ block.settings.btn_2_txt_color }}; --btn2-txt-hvr-color: {{ block.settings.btn_2_txt_hvr_color }}; --btn2-bg-color: {{ block.settings.btn_2_bg_color }}; --btn2-bg-hvr-color: {{ block.settings.btn_2_bg_hvr_color }}; --btn2-border-color: {{ block.settings.btn_2_border_color }}; --btn2-border-hvr-color: {{ block.settings.btn_2_border_hvr_color }};">
                    {{- block.settings.slider_button_2 }}
                  </a>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
    {% if section.settings.arrow_enable %}
    <div class="slider-arrow">
      <button class="arrow-prev" aria-label="arrow"><i class="feather-arrow-left"></i></button>
      <button class="arrow-next" aria-label="arrow"><i class="feather-arrow-right"></i></button>
    </div>
    {% endif %}
    {% if section.settings.dots_enable %}
    <div class="slider-dot slider-dot-{{ section.id }}"></div>
    {% endif %}
  </div>
</section>
<script type="text/javascript">
  addEventListener('DOMContentLoaded', (event) => {
    var swiper = new Swiper('#home-slider-{{ section.id }}', {
      slidesPerView: 1,
      loop: false,
      grid: {
        rows: 1,
        fill: 'row' | 'column',
      },
      spaceBetween: 0,
      autoHeight: true,
      {% if section.settings.slider_autoplay_enable %}
      autoplay: {
        delay: {{ section.settings.slider_autoplay_timeout }},
        disableOnInteraction: false,
        pauseOnMouseEnter: true
      },
      speed: {{ section.settings.slider_autoplay_speed }},
      {% endif %}
      {% if section.settings.arrow_enable %}
      navigation: {
        nextEl: ".arrow-next",
        prevEl: ".arrow-prev",
      },
      {% endif %}
      {% if section.settings.dots_enable %}
      pagination: {
        el: ".slider-dot-{{ section.id }}",
        clickable: true
      },
      {% endif %}
    });
  });
</script>
{% schema %}
{
  "name": "Slideshow",
  "settings": [
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "slider_autoplay_enable",
      "label": "Show autoplay",
      "default": true
    },
    {
      "type": "number",
      "id": "slider_autoplay_timeout",
      "label": "Autoplay timeout",
      "default": 5000,
      "info": "Put timeout by multiply 'X1000' this field"
    },
    {
      "type": "number",
      "id": "slider_autoplay_speed",
      "label": "Autoplay speed",
      "default": 1000,
      "info": "Put speed by multiply 'X100' this field"
    },
    {
      "type": "checkbox",
      "id": "arrow_enable",
      "label": "Show slider arrow",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "dots_enable",
      "label": "Show slider dots",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Shopify-hosted video"
        },
        {
          "type": "checkbox",
          "id": "enable_video_looping",
          "label": "Play video on loop",
          "default": false
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "checkbox",
          "id": "slider_video_enable",
          "default": false,
          "label": "Video enable"
        },
        {
          "type": "header",
          "content": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "slider_img",
          "label": "Image",
          "info": "Recommended size: 1920x860px"
        },
        {
          "type": "image_picker",
          "id": "slider_mobile_img",
          "label": "Mobile image",
          "info": "Recommended size: 600x600px"
        },
        {
          "type": "header",
          "content": "Text"
        },
        {
          "type": "checkbox",
          "id": "mobile_text_enable",
          "label": "Text disable on mobile",
          "default": false
        },
        {
          "type": "text",
          "id": "slider_desc",
          "label": "Subheading",
          "default": "Every step, game On!"
        },
        {
          "type": "color",
          "id": "slider_desc_color",
          "label": "Subheading color",
          "default": "#808080"
        },
        {
          "type": "text",
          "id": "slider_title",
          "label": "Heading",
          "default": "Elevate every walking moment!"
        },
        {
          "type": "color",
          "id": "slider_title_color",
          "label": "Heading color",
          "default": "#333333"
        },
        {
          "type": "header",
          "content": "Button 1"
        },
        {
          "type": "text",
          "id": "slider_button_1",
          "label": "Button label",
          "default": "Button label"
        },
        {
          "type": "color",
          "id": "btn_1_txt_color",
          "label": "Button text color",
          "default": "#222"
        },
        {
          "type": "color",
          "id": "btn_1_txt_hvr_color",
          "label": "Button text hover color",
          "default": "#fff"
        },
        {
          "type": "color",
          "id": "btn_1_bg_color",
          "label": "Button background color",
          "default": "#fff"
        },
        {
          "type": "color",
          "id": "btn_1_bg_hvr_color",
          "label": "Button hover background color",
          "default": "#D3401E"
        },
        {
          "type": "color",
          "id": "btn_1_border_color",
          "label": "Button border color",
          "default": "#D3401E"
        },
        {
          "type": "color",
          "id": "btn_1_border_hvr_color",
          "label": "Button hover border color",
          "default": "#D3401E"
        },
        {
          "type": "url",
          "id": "slider_button_1_url",
          "label": "url"
        },
        {
          "type": "header",
          "content": "Button 2"
        },
        {
          "type": "text",
          "id": "slider_button_2",
          "label": "Button label",
          "default": "Button label"
        },
        {
          "type": "color",
          "id": "btn_2_txt_color",
          "label": "Button text color",
          "default": "#222"
        },
        {
          "type": "color",
          "id": "btn_2_txt_hvr_color",
          "label": "Button text hover color",
          "default": "#fff"
        },
        {
          "type": "color",
          "id": "btn_2_bg_color",
          "label": "Button background color",
          "default": "#fff"
        },
        {
          "type": "color",
          "id": "btn_2_bg_hvr_color",
          "label": "Button hover background color",
          "default": "#D3401E"
        },
        {
          "type": "color",
          "id": "btn_2_border_color",
          "label": "Button border color",
          "default": "#D3401E"
        },
        {
          "type": "color",
          "id": "btn_2_border_hvr_color",
          "label": "Button hover border color",
          "default": "#D3401E"
        },
        {
          "type": "url",
          "id": "slider_button_2_url",
          "label": "url"
        },
        {
          "type": "header",
          "content": "Text content position"
        },
        {
          "type": "select",
          "id": "slider_content_position",
          "label": "Content position",
          "options": [
            {
              "label": "Left",
              "value": "left"
            },
            {
              "label": "Right",
              "value": "right"
            },
            {
              "label": "Center",
              "value": "center"
            }
          ],
          "default": "right"
        },
        {
          "type": "header",
          "content": "Text position"
        },
        {
          "type": "select",
          "id": "slider_text_position",
          "label": "Text position",
          "options": [
            {
              "label": "Left",
              "value": "left"
            },
            {
              "label": "Right",
              "value": "right"
            },
            {
              "label": "Center",
              "value": "center"
            }
          ],
          "default": "left"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slideshow",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
