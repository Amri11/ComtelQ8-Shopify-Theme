  .header1 .header-area {
    {% if template == 'index' and section.settings.header_transparent_enable %}
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    background-color: transparent;
    z-index: 2;
    {% else %}
    background-color: {{ section.settings.header_bgcolor }};
    {% endif %}
  }
  {% if template == 'index' %}
