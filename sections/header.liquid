{%- if settings.cart_type == 'drawer' -%}
  {%- if template.name != 'cart' -%}
    <script src="{{ 'ajax-cart.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
{%- endif -%}
<link href="{{ 'header.css' | asset_url }}" rel="stylesheet" type="text/css" media="all">
<header class="header header1">
  <div class="header-area">
    <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
      <div class="header-top">
        <div class="header-main {% if section.settings.logo_alignment == 'center' %}logo-center{% else %}logo-left{% endif %}">
          <div class="header-element toggle-content">
            <button class="navbar-toggle" aria-label="Navbar icon" type="button" aria-label="menu">
              <i class="feather-menu"></i>
            </button>
          </div>
          <div class="header-element search-desktop">
            {% render 'search-bar2' %}
          </div>
          <div class="header-element logo">
            {%- render 'company-logo' -%}
          </div>
          <div class="header-element right-block-box">
            {%- render 'header-icon', section: section -%}
          </div>
        </div>
      </div>
    </div>
    <div class="header-bottom-wrap" style="--header-bottom-bg-color: {{ section.settings.header_bottom_bg_color }};">
      <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
        <div class="header-bottom">
          <div class="header-element vegamenu-block">
            <div class="vega-menu-area">
              <a href="#vega-collapse" class="browse-cat" data-bs-toggle="collapse" aria-expanded="false" style="--vegamenu-font-size: {{ section.settings.vegamenu_font_size }}px; --vegamenu-font-size-lg: {{ section.settings.vegamenu_font_size_lg }}px; --vegamenu-text-transform: {{ section.settings.vegamenu_text_transform }};  --vegamenu-font-weight: {{ section.settings.vegamenu_font_weight }};">
                <span class="menu-icon"><i class="feather-menu"></i></span>
                <span class="menu-title">{{ section.settings.header_vega_menu_title }}</span>
              </a>
              <div class="vegawrap collapse" id="vega-collapse">
                <ul class="list-unstyled vega-menu">
                  {%- liquid
                    for block in section.blocks
                    case block.type
                    when 'vega_menu_link'
                    render 'vega-menu-link', block: block
                    when 'vega_menu_single'
                    render 'vega-menu-single', block: block
                    when 'vega_menu_sub'
                    render 'vega-menu-sub', block: block
                    when 'vega_menu_shop'
                    render 'vega-menu-shop' block: block
                    when 'vega_menu_collection'
                    render 'vega-menu-collection', block: block
                    when 'vega_menu_product'
                    render 'vega-menu-product', block: block
                    when 'vega_menu_product2'
                    render 'vega-menu-product2', block: block
                    when 'vega_menu_category'
                    render 'vega-menu-category', block: block
                    when 'vega_menu_shop_banner'
                    render 'vega-menu-shop-banner' block: block
                    endcase
                  endfor 
                  -%}
                </ul>
              </div>
            </div>
          </div>
          <div class="header-element megamenu-content">
            <nav class="mainwrap">
              <ul class="list-unstyled main-menu {% if section.settings.menu_alignment == 'center' %}menu-center{% elsif section.settings.menu_alignment == 'left' %}menu-left{% else %}menu-right{% endif %}">
                {%- liquid
                  for block in section.blocks
                    case block.type
                      when 'menu_link'
                        render 'menu-link', block: block
                      when 'menu_home'
                        render 'menu-home', block: block
                      when 'menu_single'
                        render 'menu-single', block: block
                      when 'menu_sub'
                        render 'menu-sub', block: block
                      when 'menu_shop'
                        render 'menu-shop', block: block
                      when 'menu_collection'
                        render 'menu-collection', block: block
                      when 'menu_product'
                        render 'menu-product', block: block
                      when 'menu_product2'
                        render 'menu-product2', block: block
                      when 'menu_category'
                        render 'menu-category', block: block
                      when 'company_logo'
                        render 'company-logo', block: block
                      when 'menu_shop_banner'
                        render 'menu-shop-banner', block: block
                    endcase
                  endfor
                -%}
              </ul>
            </nav>
          </div>
          {% if section.settings.head_offer_text != '' %}
          <div class="header-element head-offer-text">
            <div class="offer-text">
              <div class="offer-text-item">
                {% if section.settings.head_offer_text_1_icon != '' %}
                <span class="icon"><i class="{{ section.settings.head_offer_text_1_icon }}"></i></span>
                {% endif %}
                <div class="text" style="--offer-text-font-size: {{ section.settings.offer_text_font_size }}px; --offer-text-text-transform: {{ section.settings.offer_text_text_transform }};  --offer-text-font-weight: {{ section.settings.offer_text_font_weight }};">{{ section.settings.head_offer_text_1 }}</div>
              </div>
              <div class="offer-text-item">
                {% if section.settings.head_offer_text_2_icon != '' %}
                <span class="icon"><i class="{{ section.settings.head_offer_text_2_icon }}"></i></span>
                {% endif %}
                <div class="text" style="--offer-text-font-size: {{ section.settings.offer_text_font_size }}px; --offer-text-text-transform: {{ section.settings.offer_text_text_transform }};  --offer-text-font-weight: {{ section.settings.offer_text_font_weight }};">{{ section.settings.head_offer_text_2 }}</div>
              </div>
            </div>
          </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
  <!-- headert-top end -->
  <!-- headert-bottom start -->
  <div class="header-bottom-area">
    <div class="container header-bottom-container">
      <div class="main-menu-area">
        <div class="box-header">
