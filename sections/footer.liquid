{{ 'footer.css' | asset_url | stylesheet_tag }}
<section
  class="footer"
  style="
    {% if section.settings.section_background_image_enable %}
      background-image: url('{% if section.settings.section_background_image != blank %}{{ section.settings.section_background_image | image_url }}{% else %}https://dummyimage.com/1920x450/f7f7f7/999999{% endif %}');
    {% endif %} --padding-top: {{ section.settings.section_padding_top }}px;--padding-bottom: {{ section.settings.section_padding_bottom }}px; --padding-top-xs: {{ section.settings.section_padding_top_xs }}px;--padding-bottom-xs: {{ section.settings.section_padding_bottom_xs }}px;">
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    <div class="footer-list-wrap">
      <div class="footer-list-main">
        <ul class="list-unstyled footer-list" id="collapse-tab">
          {% for block in section.blocks %}
          {%- case block.type -%}
          {%- when 'logo_info' -%}
          <li class="ftlink-li logo-info" data-fade-in {{ block.shopify_attributes }}>
            <div class="footer-info">
              {% if block.settings.logo_enable %}
                {%- render 'company-logo-footer' -%}
              {% endif %}
              {%- if block.settings.logo_desc != '' -%}
                <p class="desc mr-0">{{ block.settings.logo_desc }}</p>
              {%- endif -%}
              {% if block.settings.footer_social_enable %}
              <div class="footer-social">
                {%- render 'social-media' -%}
              </div>
              {% endif %}
              <div class="custom-info">
                {% if block.settings.custom_info_1_label != '' or block.settings.custom_info_1_text != '' %}
                <div class="info-item">
                  {% if block.settings.custom_info_1_label != '' %}
                  <span class="label">{{ block.settings.custom_info_1_label }}</span>
                  {% endif %}
                  {% if block.settings.custom_info_1_text != '' %}
                  <div class="text">{{ block.settings.custom_info_1_text }}</div>
                  {% endif %}
                </div>
                {% endif %}
                {% if block.settings.custom_info_2_label != '' or block.settings.custom_info_2_text != '' %}
                <div class="info-item">
                  {% if block.settings.custom_info_2_label != '' %}
                  <span class="label">{{ block.settings.custom_info_2_label }}</span>
                  {% endif %}
                  {% if block.settings.custom_info_2_text != '' %}
                  <div class="text">{{ block.settings.custom_info_2_text }}</div>
                  {% endif %}
                </div>
                {% endif %}
                {% if block.settings.custom_info_3_label != '' or block.settings.custom_info_3_text != '' %}
                <div class="info-item">
                  {% if block.settings.custom_info_3_label != '' %}
                  <span class="label">{{ block.settings.custom_info_3_label }}</span>
                  {% endif %}
                  {% if block.settings.custom_info_3_text != '' %}
                  <div class="text">{{ block.settings.custom_info_3_text }}</div>
                  {% endif %}
                </div>
                {% endif %}
              </div>
            </div>
          </li>
          {%- when 'footer_menu' -%}
          <li class="ftlink-li link-list" data-fade-in {{ block.shopify_attributes }}>
            {% assign footer_menu = block.settings.footer_menu_handle %}
            {%- assign nav_title = block.settings.nav_title | default: linklists[footer_menu].title -%}
            {%- if block.settings.show_nav_title -%}
              <h2 class="ft-title mr-0">{{ nav_title }}</h2>
              <button
                type="button"
                data-bs-toggle="collapse"
                aria-expanded="false"
                data-bs-target="#collapse-{{ block.id }}"
                class="ft-title accordian-btn"
                aria-label="{{ nav_title }}"
              >
                <span>{{ nav_title }}</span>
                <i class="feather-plus"></i>
              </button>
            {%- endif -%}
            <ul
              class="list-unstyled {% if block.settings.show_nav_title %}accordian-content collapse {% endif %} footer-sublist link"
              {%- if block.settings.show_nav_title -%}
                id="collapse-{{ block.id }}"
                data-bs-parent="#collapse-tab"
              {%- endif -%}
            >
              {% assign footer_menu = block.settings.footer_menu_handle %}
              {% for link in linklists[footer_menu].links limit: 6 %}
                {% if linklists[footer_menu].links != '' %}
                  <li class="ftsublink-li">
                    <a href="{{ link.url }}" class="ft-sublink">{{ link.title }}</a>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          </li>
          {%- when 'contact_info' -%}
          <li class="ftlink-li contact-info" data-fade-in {{ block.shopify_attributes }}>
            {%- if block.settings.show_nav_title -%}
            <h2 class="ft-title mr-0">{{ block.settings.contact_info_title }}</h2>
            <button
              type="button"
              data-bs-toggle="collapse"
              aria-expanded="false"
              data-bs-target="#collapse-{{ block.id }}"
              class="ft-title accordian-btn"
              aria-label="{{ block.settings.contact_info_title }}"
            >
              <span>{{ block.settings.contact_info_title }}</span>
              <i class="feather-plus"></i>
            </button>
            {%- endif -%}
            <ul class="list-unstyled {% if block.settings.show_nav_title %}accordian-content collapse {% endif %} footer-sublist"
              {%- if block.settings.show_nav_title -%}
                id="collapse-{{ block.id }}"
                data-bs-parent="#collapse-tab"
              {%- endif -%}
            >
              <li>
                <div class="contact-info-wrap">
                  <div class="contact-info-item">
                    {% if block.settings.contact_info_1_icon != '' %}
                    <span class="contact-info-icon">
                      <i class="{{ block.settings.contact_info_1_icon }}"></i>
                    </span>
                    {% endif %}
                    {% if block.settings.contact_info_1_text != '' %}
                    <div class="contact-info-text">{{ block.settings.contact_info_1_text }}</div>
                    {% endif %}
                  </div>
                  <div class="contact-info-item">
                    {% if block.settings.contact_info_2_icon != '' %}
                    <span class="contact-info-icon">
                      <i class="{{ block.settings.contact_info_2_icon }}"></i>
                    </span>
                    {% endif %}
                    {% if block.settings.contact_info_2_text != '' %}
                    <div class="contact-info-text">{{ block.settings.contact_info_2_text }}</div>
                    {% endif %}
                  </div>
                  <div class="contact-info-item">
                    {% if block.settings.contact_info_3_icon != '' %}
                    <span class="contact-info-icon">
                      <i class="{{ block.settings.contact_info_3_icon }}"></i>
                    </span>
                    {% endif %}
                    {% if block.settings.contact_info_3_text != '' %}
                    <div class="contact-info-text">{{ block.settings.contact_info_3_text }}</div>
                    {% endif %}
                  </div>
                </div>
              </li>
            </ul>
          </li>

          {%- when 'social_payment' -%}
          <li class="ftlink-li social-payment" data-fade-in {{ block.shopify_attributes }}>
            <div class="social-payment-wrap">
              <div class="social-area">
                {%- if block.settings.footer_social_title -%}
                <h2 class="ft-title mr-0">{{ block.settings.footer_social_title }}</h2>
                {%- endif -%}
                {% render 'social-media' %}
              </div>
              <div class="payment-area">
                {%- if block.settings.footer_payment_title -%}
                  <h2 class="ft-title mr-0">{{ block.settings.footer_payment_title }}</h2>
                  {%- endif -%}
                  {% render 'payment-icon' %}
              </div>
            </div>
          </li>

          {%- when 'store_time' -%}
          <li class="ftlink-li store-time" data-fade-in {{ block.shopify_attributes }}>
            {%- if block.settings.show_nav_title -%}
            <h2 class="ft-title mr-0">{{ block.settings.store_time_title }}</h2>
            {%- endif -%}
            <div class="store-time-wrap">
              {% if block.settings.store_time_1_label != '' or block.settings.store_time_1_text != '' %}
              <div class="text-item">
                {% if block.settings.store_time_1_label != '' %}
                <span class="label">{{ block.settings.store_time_1_label }}</span>
                {% endif %}
                {% if block.settings.store_time_1_text != '' %}
                <span class="text">{{ block.settings.store_time_1_text }}</span>
                {% endif %}
              </div>
              {% endif %}
              {% if block.settings.store_time_2_label != '' or block.settings.store_time_2_text != '' %}
              <div class="text-item">
                {% if block.settings.store_time_2_label != '' %}
                <span class="label">{{ block.settings.store_time_2_label }}</span>
                {% endif %}
                {% if block.settings.store_time_2_text != '' %}
                <span class="text">{{ block.settings.store_time_2_text }}</span>
                {% endif %}
              </div>
              {% endif %}
              {% if block.settings.store_time_3_label != '' or block.settings.store_time_3_text != '' %}
              <div class="text-item">
                {% if block.settings.store_time_3_label != '' %}
                <span class="label">{{ block.settings.store_time_3_label }}</span>
                {% endif %}
                {% if block.settings.store_time_3_text != '' %}
                <span class="text">{{ block.settings.store_time_3_text }}</span>
                {% endif %}
              </div>
              {% endif %}
            </div>
          </li>        
          {%- endcase -%}
          {%- endfor -%}
        </ul>
      </div>
      {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
      <div class="footer__follow-on-shop">
        {{ shop | login_button: action: 'follow' }}
      </div>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
