{% endschema %}
<style>
  :root {
    --footer-menu-title-font-size: {{ section.settings.menu_title_font_size }}px;
    --footer-menu-title-font-size-lg: {{ section.settings.menu_title_font_size_lg }}px;
    --footer-menu-title-font-weight: {{ section.settings.menu_title_font_weight }};
    --footer-menu-title-text-transform: {{ section.settings.menu_title_text_transform }};
    --footer-menu-title-color: {{ section.settings.menu_title_color }};
    --footer-menu-text-font-size: {{ section.settings.menu_text_font_size }}px;
    --footer-menu-text-font-size-lg: {{ section.settings.menu_text_font_size_lg }}px;
    --footer-menu-text-font-weight: {{ section.settings.menu_text_font_weight }};
    --footer-menu-text-transform: {{ section.settings.menu_text_text_transform }};
    --footer-menu-text-color: {{ section.settings.menu_text_color }};
    --footer-menu-text-hover-color: {{ section.settings.menu_text_hv_color }};
  }
  .footer{
    position: relative;
    {% if section.settings.section_background_image_enable %}
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center;
    {% endif %}
    background-color: {{ section.settings.section_background_color }};
  }
</style>
